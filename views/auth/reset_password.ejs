<%- include('../partials/header', { title: 'Reset Password – StudentVault' }) %>

<div class="min-h-screen flex items-center justify-center px-4" style="background: var(--bg-primary);">
  <div class="w-full max-w-md">

    <div class="sv-card p-8">
      <!-- Icon -->
      <div class="flex justify-center mb-6">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center shadow-lg"
          style="background: linear-gradient(135deg,#10b981,#065f46);">
          <i class="fa-solid fa-key text-white text-2xl"></i>
        </div>
      </div>

      <h1 class="text-2xl font-extrabold text-center mb-2" style="color:var(--text-primary);">Set New Password</h1>
      <p class="text-center text-sm mb-8" style="color:var(--text-muted);">
        Enter a strong new password. Minimum 6 characters.
      </p>

      <form id="resetForm" onsubmit="handleReset(event)" class="space-y-5">
        <div>
          <label class="sv-label">New Password</label>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-sm" style="color:var(--text-muted);"></i>
            <input type="password" id="new-password" class="sv-input pl-11 pr-11"
              placeholder="••••••••" minlength="6" required>
            <button type="button" onclick="togglePwd('new-password', this)"
              class="absolute right-3 top-1/2 -translate-y-1/2" style="color:var(--text-muted);">
              <i class="fa-regular fa-eye"></i>
            </button>
          </div>
        </div>

        <div>
          <label class="sv-label">Confirm New Password</label>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-sm" style="color:var(--text-muted);"></i>
            <input type="password" id="confirm-password" class="sv-input pl-11 pr-11"
              placeholder="••••••••" minlength="6" required>
            <button type="button" onclick="togglePwd('confirm-password', this)"
              class="absolute right-3 top-1/2 -translate-y-1/2" style="color:var(--text-muted);">
              <i class="fa-regular fa-eye"></i>
            </button>
          </div>
        </div>

        <!-- Strength bar -->
        <div>
          <div class="h-1.5 rounded-full overflow-hidden" style="background:var(--border);">
            <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%; background:#ef4444;"></div>
          </div>
          <p id="strength-label" class="text-xs mt-1" style="color:var(--text-muted);">Password strength</p>
        </div>

        <button type="submit" id="resetBtn" class="sv-btn sv-btn-success w-full justify-center py-3 text-base">
          <i class="fa-solid fa-shield-halved"></i> Reset Password
        </button>
      </form>

      <!-- Success state -->
      <div id="successState" class="hidden text-center py-4">
        <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4" style="background:#d1fae5;">
          <i class="fa-solid fa-circle-check text-emerald-500 text-2xl"></i>
        </div>
        <p class="font-bold text-lg mb-2" style="color:var(--text-primary);">Password Updated!</p>
        <p class="text-sm mb-6" style="color:var(--text-muted);">Your password has been reset successfully.</p>
        <a href="/login" class="sv-btn sv-btn-primary">
          <i class="fa-solid fa-right-to-bracket"></i> Sign In Now
        </a>
      </div>

      <p class="mt-6 text-center text-sm" style="color:var(--text-muted);">
        <a href="/login" class="font-bold" style="color:var(--accent);">← Back to Sign In</a>
      </p>
    </div>

  </div>
</div>

<script>
const RESET_TOKEN = '<%= token %>';

// Strength meter
document.getElementById('new-password').addEventListener('input', function() {
  const val  = this.value;
  const bar  = document.getElementById('strength-bar');
  const lbl  = document.getElementById('strength-label');
  let score  = 0;
  if (val.length >= 6) score++;
  if (val.length >= 10) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const map = [
    { w:'0%',  c:'#ef4444', t:'Too short' },
    { w:'25%', c:'#ef4444', t:'Weak' },
    { w:'50%', c:'#f59e0b', t:'Fair' },
    { w:'75%', c:'#3b82f6', t:'Good' },
    { w:'90%', c:'#10b981', t:'Strong' },
    { w:'100%',c:'#059669', t:'Very Strong' }
  ];
  bar.style.width      = map[score].w;
  bar.style.background = map[score].c;
  lbl.textContent      = map[score].t;
  lbl.style.color      = map[score].c;
});

function togglePwd(id, btn) {
  const inp    = document.getElementById(id);
  const isText = inp.type === 'text';
  inp.type     = isText ? 'password' : 'text';
  btn.innerHTML = isText ? '<i class="fa-regular fa-eye"></i>' : '<i class="fa-regular fa-eye-slash"></i>';
}

async function handleReset(e) {
  e.preventDefault();
  const pwd  = document.getElementById('new-password').value;
  const cpwd = document.getElementById('confirm-password').value;
  if (pwd !== cpwd) { showToast('Passwords do not match', 'error'); return; }
  if (pwd.length < 6) { showToast('Minimum 6 characters required', 'warning'); return; }

  const btn = document.getElementById('resetBtn');
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Updating…';
  btn.disabled  = true;

  try {
    const res  = await fetch(`/api/password/reset/${RESET_TOKEN}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pwd })
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('resetForm').classList.add('hidden');
      document.getElementById('successState').classList.remove('hidden');
      showToast('✅ Password reset successfully!', 'success');
    } else {
      showToast(data.message || 'Reset failed', 'error');
      btn.innerHTML = '<i class="fa-solid fa-shield-halved"></i> Reset Password';
      btn.disabled  = false;
    }
  } catch {
    showToast('Network error', 'error');
    btn.innerHTML = '<i class="fa-solid fa-shield-halved"></i> Reset Password';
    btn.disabled  = false;
  }
}
</script>

<%- include('../partials/footer') %>
