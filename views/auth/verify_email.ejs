<%- include('../partials/header', { title: 'Email Verification – StudentVault' }) %>

<style>
body { overflow: auto !important; height: auto !important; }
@keyframes popIn {
    0%   { transform: scale(0.7); opacity: 0; }
    70%  { transform: scale(1.08); }
    100% { transform: scale(1); opacity: 1; }
}
@keyframes blobFloat {
    0%,100% { transform: translateY(0) scale(1); }
    50%      { transform: translateY(-18px) scale(1.04); }
}
.blob {
    position: absolute; border-radius: 50%;
    filter: blur(70px); opacity: 0.15;
    animation: blobFloat 9s ease-in-out infinite;
}
.icon-wrap { animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) both; }
</style>

<div class="min-h-screen flex items-center justify-center p-6 relative overflow-hidden"
    style="background: linear-gradient(135deg, #0e3a5e 0%, #1485e0 60%, #0c4a6e 100%);">

    <!-- Background blobs -->
    <div class="blob w-80 h-80 bg-blue-300 top-10 left-10"></div>
    <div class="blob w-64 h-64 bg-indigo-400 bottom-10 right-10" style="animation-delay:4s;"></div>

    <div class="relative z-10 w-full max-w-md">
        <!-- Card -->
        <div class="rounded-2xl p-8 sm:p-10 text-center" style="background: var(--bg-card); box-shadow: 0 20px 60px rgba(0,0,0,0.35);">

            <!-- Logo -->
            <div class="flex items-center justify-center gap-2 mb-8">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg,#1485e0,#0e3a5e);">
                    <i class="fa-solid fa-building-columns text-white text-sm"></i>
                </div>
                <span class="font-bold text-lg" style="color: var(--text-primary);">StudentVault</span>
            </div>

            <% if (status === 'success') { %>
                <!-- ── SUCCESS ── -->
                <div class="icon-wrap w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background: #d1fae5;">
                    <i class="fa-solid fa-circle-check text-4xl text-emerald-500"></i>
                </div>
                <h1 class="text-2xl font-extrabold mb-2" style="color: var(--text-primary);">Email Verified!</h1>
                <p class="text-sm mb-8 leading-relaxed" style="color: var(--text-muted);">
                    Your email address has been successfully verified. You can now log in to your StudentVault account.
                </p>
                <a href="/login" class="sv-btn sv-btn-primary w-full justify-center py-3 text-base">
                    <i class="fa-solid fa-right-to-bracket"></i> Go to Login
                </a>

            <% } else if (status === 'invalid') { %>
                <!-- ── INVALID / EXPIRED ── -->
                <div class="icon-wrap w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background: #fee2e2;">
                    <i class="fa-solid fa-circle-xmark text-4xl text-red-500"></i>
                </div>
                <h1 class="text-2xl font-extrabold mb-2" style="color: var(--text-primary);">Link Invalid or Expired</h1>
                <p class="text-sm mb-8 leading-relaxed" style="color: var(--text-muted);">
                    This verification link is invalid or has already been used. Please register again to get a new link.
                </p>
                <div class="flex flex-col gap-3">
                    <a href="/signup" class="sv-btn sv-btn-primary w-full justify-center py-3 text-base">
                        <i class="fa-solid fa-user-plus"></i> Register Again
                    </a>
                    <a href="/login" class="sv-btn sv-btn-secondary w-full justify-center py-2.5 text-sm">
                        Back to Login
                    </a>
                </div>

            <% } else { %>
                <!-- ── PENDING / DEFAULT ── -->
                <div class="icon-wrap w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background: #dbeafe;">
                    <i class="fa-regular fa-envelope text-4xl" style="color: #1485e0;"></i>
                </div>
                <h1 class="text-2xl font-extrabold mb-2" style="color: var(--text-primary);">Check Your Email</h1>
                <p class="text-sm mb-6 leading-relaxed" style="color: var(--text-muted);">
                    We sent a verification link to your email address. Please click the link to activate your account.
                </p>
                <div class="rounded-xl p-4 mb-7 text-left" style="background: var(--bg-primary); border: 1px solid var(--border);">
                    <div class="flex items-start gap-3">
                        <i class="fa-solid fa-circle-info mt-0.5 flex-shrink-0" style="color: #1485e0;"></i>
                        <div class="text-xs space-y-1" style="color: var(--text-secondary);">
                            <p>• Check your <strong>spam/junk</strong> folder if you don't see it</p>
                            <p>• The link expires in <strong>24 hours</strong></p>
                            <p>• You cannot log in until your email is verified</p>
                        </div>
                    </div>
                </div>
                <a href="/login" class="sv-btn sv-btn-secondary w-full justify-center py-2.5 text-sm">
                    Back to Login
                </a>
            <% } %>

        </div>

        <p class="text-center text-blue-300 text-xs mt-6">© 2025 StudentVault. University Library System.</p>
    </div>
</div>

<%- include('../partials/footer') %>
