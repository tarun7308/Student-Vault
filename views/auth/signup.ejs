<%- include('../partials/header', { title: 'Create Account – StudentVault' }) %>

<style>
body { overflow: auto !important; height: auto !important; }
.auth-bg {
    background: linear-gradient(135deg, #0e3a5e 0%, #1485e0 50%, #0c4a6e 100%);
    position: relative; overflow: hidden;
}
.auth-blob {
    position: absolute; border-radius: 50%;
    filter: blur(70px); opacity: 0.18;
    animation: blobFloat 8s ease-in-out infinite;
}
@keyframes blobFloat {
    0%,100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
}
.role-tab { transition: all 0.25s; cursor: pointer; }
.role-tab.active {
    background: linear-gradient(135deg, #1485e0, #0e3a5e);
    color: white; box-shadow: 0 4px 14px rgba(20,133,224,0.35);
}
.avatar-ring {
    width: 72px; height: 72px; border-radius: 50%;
    border: 3px solid var(--border);
    overflow: hidden; cursor: pointer;
    transition: all 0.25s;
    position: relative;
}
.avatar-ring:hover { border-color: var(--accent); transform: scale(1.05); }
.avatar-ring .overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.2s;
}
.avatar-ring:hover .overlay { opacity: 1; }
</style>

<div class="min-h-screen flex">
    <!-- Left Panel -->
    <div class="auth-bg hidden lg:flex lg:w-5/12 flex-col justify-between p-12 relative">
        <div class="auth-blob w-80 h-80 bg-blue-300 top-5 left-5"></div>
        <div class="auth-blob w-60 h-60 bg-indigo-400 bottom-10 right-5" style="animation-delay:4s;"></div>

        <div class="relative z-10 flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-white/20 backdrop-blur">
                <i class="fa-solid fa-building-columns text-white"></i>
            </div>
            <span class="text-white font-bold text-xl">StudentVault</span>
        </div>

        <div class="relative z-10">
            <i class="fa-solid fa-book-open-reader text-6xl text-blue-200 mb-6 block"></i>
            <h2 class="text-4xl font-extrabold text-white leading-tight mb-4">
                Join the Smart<br/>Library Network
            </h2>
            <p class="text-blue-200 text-base leading-relaxed">
                Issue books, track due dates, pay fines digitally — all through a single modern dashboard built for university life.
            </p>

            <div class="mt-8 space-y-3">
                <div class="flex items-center gap-3 text-blue-100">
                    <div class="w-7 h-7 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                        <i class="fa-solid fa-check text-xs text-white"></i>
                    </div>
                    <span class="text-sm">Browse & Request books online</span>
                </div>
                <div class="flex items-center gap-3 text-blue-100">
                    <div class="w-7 h-7 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                        <i class="fa-solid fa-check text-xs text-white"></i>
                    </div>
                    <span class="text-sm">Track due dates & fine calculator</span>
                </div>
                <div class="flex items-center gap-3 text-blue-100">
                    <div class="w-7 h-7 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                        <i class="fa-solid fa-check text-xs text-white"></i>
                    </div>
                    <span class="text-sm">Digital library ID card</span>
                </div>
            </div>
        </div>

        <div class="relative z-10 text-blue-300 text-sm">© 2025 StudentVault.</div>
    </div>

    <!-- Right Panel: Form -->
    <div class="flex-1 flex items-center justify-center p-6 sm:p-10 overflow-y-auto" style="background: var(--bg-primary);">
        <div class="w-full max-w-lg">

            <!-- Mobile logo -->
            <div class="lg:hidden flex items-center gap-3 mb-8">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg,#1485e0,#0e3a5e);">
                    <i class="fa-solid fa-building-columns text-white"></i>
                </div>
                <span class="font-bold text-xl" style="color: var(--text-primary);">StudentVault</span>
            </div>

            <h2 class="text-3xl font-extrabold mb-1" style="color: var(--text-primary);">Create Account</h2>
            <p class="mb-7 text-sm" style="color: var(--text-muted);">Fill in your details to get started.</p>

            <!-- Role Toggle -->
            <div class="flex p-1 rounded-xl mb-6 gap-1" style="background: var(--bg-card); border: 1.5px solid var(--border);">
                <button type="button" id="btn-signup-student" onclick="setSignupRole('student')"
                    class="role-tab active flex-1 py-2.5 text-sm font-semibold rounded-lg">
                    <i class="fa-solid fa-user-graduate mr-1.5"></i>Student
                </button>
                <button type="button" id="btn-signup-librarian" onclick="setSignupRole('librarian')"
                    class="role-tab flex-1 py-2.5 text-sm font-semibold rounded-lg" style="color: var(--text-muted);">
                    <i class="fa-solid fa-user-tie mr-1.5"></i>Librarian
                </button>
            </div>

            <form id="signupForm" class="space-y-5" onsubmit="handleSignup(event)">
                <input type="hidden" id="signup-role" name="role" value="student">

                <!-- Avatar Upload -->
                <div class="flex items-center gap-5">
                    <label for="profilePic" class="avatar-ring flex-shrink-0">
                        <img id="preview-img" src="https://ui-avatars.com/api/?name=U&background=e0f2fe&color=1485e0&bold=true&size=80" alt="Profile" class="w-full h-full object-cover">
                        <div class="overlay">
                            <i class="fa-solid fa-camera text-white text-lg"></i>
                        </div>
                    </label>
                    <div>
                        <p class="text-sm font-semibold mb-1" style="color: var(--text-primary);">Profile Photo</p>
                        <p class="text-xs mb-2" style="color: var(--text-muted);">Click avatar to upload (optional)</p>
                        <input type="file" id="profilePic" name="profilePic" accept="image/*" class="hidden" onchange="previewImage(event)">
                    </div>
                </div>

                <!-- Name -->
                <div>
                    <label class="sv-label">Full Name</label>
                    <div class="relative">
                        <i class="fa-solid fa-user absolute left-3.5 top-1/2 -translate-y-1/2 text-sm" style="color: var(--text-muted);"></i>
                        <input type="text" id="name" name="name" required
                            class="sv-input pl-10" placeholder="Arjun Sharma" oninput="updatePreview()">
                    </div>
                </div>

                <!-- Email -->
                <div>
                    <label class="sv-label">University Email</label>
                    <div class="relative">
                        <i class="fa-regular fa-envelope absolute left-3.5 top-1/2 -translate-y-1/2 text-sm" style="color: var(--text-muted);"></i>
                        <input type="email" id="email" name="email" required
                            class="sv-input pl-10" placeholder="arjun@university.edu">
                    </div>
                </div>

                <!-- Password -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="sv-label">Password</label>
                        <div class="relative">
                            <i class="fa-solid fa-lock absolute left-3.5 top-1/2 -translate-y-1/2 text-sm" style="color: var(--text-muted);"></i>
                            <input type="password" id="password" name="password" required
                                class="sv-input pl-10" placeholder="Min. 6 chars">
                        </div>
                    </div>
                    <div>
                        <label class="sv-label">Confirm Password</label>
                        <div class="relative">
                            <i class="fa-solid fa-lock absolute left-3.5 top-1/2 -translate-y-1/2 text-sm" style="color: var(--text-muted);"></i>
                            <input type="password" id="confirmPassword" required
                                class="sv-input pl-10" placeholder="Repeat password">
                        </div>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" id="signupBtn" class="sv-btn sv-btn-primary w-full justify-center py-3 text-base mt-2">
                    <i class="fa-solid fa-user-plus"></i> Create Account
                </button>
            </form>

            <!-- Divider -->
            <div class="relative my-6">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full" style="border-top: 1px solid var(--border);"></div>
                </div>
                <div class="relative flex justify-center">
                    <span class="px-4 text-xs font-medium" style="background: var(--bg-primary); color: var(--text-muted);">OR</span>
                </div>
            </div>

            <a href="/api/auth/google"
                class="flex items-center justify-center gap-3 w-full py-2.5 px-4 rounded-xl text-sm font-semibold transition-all hover:scale-[1.02]"
                style="background: var(--bg-card); border: 1.5px solid var(--border); color: var(--text-secondary);">
                <svg class="w-4 h-4" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9 3.2l6.7-6.7C35.7 2.5 30.2 0 24 0 14.8 0 6.9 5.4 3 13.3l7.8 6C12.7 13.3 17.9 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.6 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8C43.5 37.5 46.6 31.5 46.6 24.5z"/>
                    <path fill="#FBBC05" d="M10.8 28.7c-.6-1.7-.9-3.5-.9-5.2s.3-3.5.9-5.2L3 12.3C1.1 16 0 20.1 0 24.5s1.1 8.5 3 12.2l7.8-6z"/>
                    <path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.5-5.8c-2 1.4-4.6 2.2-7.7 2.2-6.1 0-11.3-3.8-13.2-9.3l-7.8 6C6.9 42.6 14.8 48 24 48z"/>
                </svg>
                Sign up with Google
            </a>

            <p class="mt-6 text-center text-sm" style="color: var(--text-muted);">
                Already have an account?
                <a href="/login" class="font-bold" style="color: var(--accent);">Sign In</a>
            </p>
        </div>
    </div>
</div>

<script>
function setSignupRole(role) {
    document.getElementById('signup-role').value = role;
    const s = document.getElementById('btn-signup-student');
    const l = document.getElementById('btn-signup-librarian');
    if (role === 'student') {
        s.classList.add('active');
        s.style.color = '';
        l.classList.remove('active');
        l.style.color = 'var(--text-muted)';
    } else {
        l.classList.add('active');
        l.style.color = '';
        s.classList.remove('active');
        s.style.color = 'var(--text-muted)';
    }
}

function updatePreview() {
    const name = document.getElementById('name').value || 'U';
    const img  = document.getElementById('preview-img');
    if (img.src.includes('ui-avatars')) {
        img.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=e0f2fe&color=1485e0&bold=true&size=80`;
    }
}

function previewImage(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => { document.getElementById('preview-img').src = reader.result; };
    reader.readAsDataURL(file);
}

async function handleSignup(e) {
    e.preventDefault();
    const pwd = document.getElementById('password').value;
    const cpwd = document.getElementById('confirmPassword').value;
    if (pwd !== cpwd) { showToast('Passwords do not match!', 'error'); return; }
    if (pwd.length < 6) { showToast('Password must be at least 6 characters.', 'warning'); return; }

    const btn = document.getElementById('signupBtn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating...';
    btn.disabled = true;

    const formData = new FormData(document.getElementById('signupForm'));
    try {
        const res  = await fetch('/api/auth/signup', { method: 'POST', body: formData, credentials: 'same-origin' });
        const data = await res.json();
        if (data.success) {
            if (data.emailSent) {
                showToast('✅ Account created! Check your email to verify.', 'success', 4000);
                setTimeout(() => { window.location.href = '/verify-email'; }, 1500);
            } else {
                showToast('🎉 Account created! You can now sign in.', 'success', 3000);
                setTimeout(() => { window.location.href = '/login?registered=1'; }, 1200);
            }
        } else {
            showToast(data.message || 'Signup failed.', 'error');
            btn.innerHTML = '<i class="fa-solid fa-user-plus"></i> Create Account';
            btn.disabled = false;
        }
    } catch (err) {
        showToast('Network error. Please try again.', 'error');
        btn.innerHTML = '<i class="fa-solid fa-user-plus"></i> Create Account';
        btn.disabled = false;
    }
}
</script>

<%- include('../partials/footer') %>
