<%- include('../partials/header', { title: 'Book Categories – StudentVault' }) %>

<div class="flex h-screen w-full overflow-hidden">
<%- include('../partials/sidebar', { role, path }) %>
<div class="flex-1 flex flex-col overflow-hidden">
<%- include('../partials/navbar', { role }) %>

<main class="flex-1 overflow-y-auto p-5 sm:p-7" style="background: var(--bg-primary);">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-7">
        <div>
            <h1 class="text-2xl font-extrabold" style="color: var(--text-primary);">Book Categories</h1>
            <p class="text-sm mt-1" style="color: var(--text-muted);">Manage the categories used for organising the library's books.</p>
        </div>
        <div class="flex gap-3">
            <% if (!categories || categories.length === 0) { %>
            <button onclick="seedCategories()" class="sv-btn sv-btn-secondary">
                <i class="fa-solid fa-wand-magic-sparkles"></i> Seed Defaults
            </button>
            <% } %>
            <button onclick="toggleModal('addCatModal')" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-plus"></i> Add Category
            </button>
        </div>
    </div>

    <!-- Categories Grid -->
    <% if (categories && categories.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% categories.forEach(cat => { %>
        <div class="sv-card overflow-hidden flex flex-col">

            <!-- Card Header -->
            <div class="p-5 flex items-center justify-between" style="border-bottom: 1px solid var(--border);">
                <div class="flex items-center gap-3">
                    <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                        style="background: <%= cat.color %>22;">
                        <i class="fa-solid <%= cat.icon %> text-lg" style="color: <%= cat.color %>;"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-base" style="color: var(--text-primary);"><%= cat.name %></h3>
                        <p class="text-xs" style="color: var(--text-muted);">
                            <%= cat.bookCount %> book<%= cat.bookCount !== 1 ? 's' : '' %>
                        </p>
                    </div>
                </div>
                <div class="flex gap-1.5">
                    <button onclick="openEditCat('<%= cat._id %>', '<%= cat.name.replace(/'/g, `\\'`) %>', '<%= cat.color %>', '<%= cat.icon %>')"
                        class="w-8 h-8 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                        style="background: #dbeafe; color: #1d4ed8;" title="Edit">
                        <i class="fa-solid fa-pen text-xs"></i>
                    </button>
                    <button onclick="deleteCat('<%= cat._id %>', '<%= cat.name.replace(/'/g, `\\'`) %>')"
                        class="w-8 h-8 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                        style="background: #fee2e2; color: #dc2626;" title="Delete">
                        <i class="fa-solid fa-trash text-xs"></i>
                    </button>
                </div>
            </div>

            <!-- Books List -->
            <div class="flex-1 p-4 space-y-2 overflow-y-auto" style="max-height: 220px;">
                <% if (cat.books && cat.books.length > 0) { %>
                    <% cat.books.slice(0, 6).forEach(book => { %>
                    <div class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg"
                        style="background: var(--bg-primary);">
                        <div class="min-w-0">
                            <p class="text-sm font-semibold truncate" style="color: var(--text-primary);"><%= book.title %></p>
                            <p class="text-xs truncate" style="color: var(--text-muted);">by <%= book.author %></p>
                        </div>
                        <span class="sv-badge text-xs flex-shrink-0 <%= book.availableCopies > 0 ? 'sv-badge-green' : 'sv-badge-red' %>">
                            <%= book.availableCopies %>/<%= book.totalCopies %>
                        </span>
                    </div>
                    <% }) %>
                    <% if (cat.books.length > 6) { %>
                    <p class="text-xs text-center pt-1" style="color: var(--text-muted);">
                        +<%= cat.books.length - 6 %> more books
                    </p>
                    <% } %>
                <% } else { %>
                <div class="py-6 text-center">
                    <i class="fa-solid fa-book text-2xl mb-2 block" style="color: var(--border);"></i>
                    <p class="text-xs" style="color: var(--text-muted);">No books in this category yet.</p>
                    <p class="text-xs mt-1" style="color: var(--text-muted);">Assign this category when adding/editing books.</p>
                </div>
                <% } %>
            </div>

            <!-- Footer: colour bar + Manage link -->
            <div class="h-1" style="background: <%= cat.color %>;"></div>
            <div class="px-5 py-3" style="border-top: 1px solid var(--border);">
                <a href="/librarian/books?category=<%= encodeURIComponent(cat.name) %>"
                    class="text-xs font-bold flex items-center gap-1.5 hover:underline" style="color: <%= cat.color %>;">
                    <i class="fa-solid fa-arrow-right"></i> Manage Books in this Category
                </a>
            </div>
        </div>
        <% }) %>
    </div>
    <% } else { %>
    <div class="sv-card p-16 text-center">
        <i class="fa-solid fa-tags text-5xl mb-4 block" style="color: var(--border);"></i>
        <p class="text-lg font-bold mb-2" style="color: var(--text-primary);">No categories yet</p>
        <p class="text-sm mb-6" style="color: var(--text-muted);">Seed default categories or add your own.</p>
        <button onclick="seedCategories()" class="sv-btn sv-btn-primary mr-3">
            <i class="fa-solid fa-wand-magic-sparkles"></i> Seed Defaults
        </button>
        <button onclick="toggleModal('addCatModal')" class="sv-btn sv-btn-secondary">
            <i class="fa-solid fa-plus"></i> Add Category
        </button>
    </div>
    <% } %>


</main>
</div>
</div>

<!-- ADD CATEGORY MODAL -->
<div id="addCatModal" class="sv-modal-overlay">
    <div class="sv-modal">
        <div class="sv-modal-header">
            <h3 class="text-lg font-bold" style="color: var(--text-primary);">Add Category</h3>
            <button onclick="toggleModal('addCatModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--bg-primary); color: var(--text-muted);">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="sv-modal-body space-y-4">
            <div>
                <label class="sv-label">Category Name <span class="text-red-500">*</span></label>
                <input type="text" id="add-cat-name" class="sv-input" placeholder="e.g. Philosophy">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="sv-label">Color</label>
                    <div class="flex items-center gap-3">
                        <input type="color" id="add-cat-color" value="#3b82f6"
                            class="w-10 h-10 rounded-lg cursor-pointer border" style="border: 1.5px solid var(--border);" oninput="updatePreviewColor('add')">
                        <span id="add-cat-color-hex" class="text-sm font-mono" style="color: var(--text-muted);">#3b82f6</span>
                    </div>
                </div>
                <div>
                    <label class="sv-label">Icon (FA class)</label>
                    <input type="text" id="add-cat-icon" class="sv-input" value="fa-book" placeholder="fa-book">
                </div>
            </div>
            <!-- Preview -->
            <div class="flex items-center gap-3 p-4 rounded-xl" style="background: var(--bg-primary); border: 1.5px solid var(--border);">
                <div id="add-preview-icon" class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: #3b82f622;">
                    <i id="add-preview-i" class="fa-solid fa-book text-lg" style="color: #3b82f6;"></i>
                </div>
                <p id="add-preview-name" class="font-semibold text-sm" style="color: var(--text-primary);">Category Preview</p>
            </div>
        </div>
        <div class="sv-modal-footer">
            <button onclick="toggleModal('addCatModal')" class="sv-btn sv-btn-secondary">Cancel</button>
            <button onclick="handleAddCat()" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-plus"></i> Add Category
            </button>
        </div>
    </div>
</div>

<!-- EDIT CATEGORY MODAL -->
<div id="editCatModal" class="sv-modal-overlay">
    <div class="sv-modal">
        <div class="sv-modal-header">
            <h3 class="text-lg font-bold" style="color: var(--text-primary);">Edit Category</h3>
            <button onclick="toggleModal('editCatModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--bg-primary); color: var(--text-muted);">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="sv-modal-body space-y-4">
            <input type="hidden" id="edit-cat-id">
            <div>
                <label class="sv-label">Category Name</label>
                <input type="text" id="edit-cat-name" class="sv-input">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="sv-label">Color</label>
                    <div class="flex items-center gap-3">
                        <input type="color" id="edit-cat-color" class="w-10 h-10 rounded-lg cursor-pointer border" style="border: 1.5px solid var(--border);" oninput="updatePreviewColor('edit')">
                        <span id="edit-cat-color-hex" class="text-sm font-mono" style="color: var(--text-muted);"></span>
                    </div>
                </div>
                <div>
                    <label class="sv-label">Icon (FA class)</label>
                    <input type="text" id="edit-cat-icon" class="sv-input">
                </div>
            </div>
        </div>
        <div class="sv-modal-footer">
            <button onclick="toggleModal('editCatModal')" class="sv-btn sv-btn-secondary">Cancel</button>
            <button onclick="handleEditCat()" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
        </div>
    </div>
</div>

<script>
function updatePreviewColor(prefix) {
    const color = document.getElementById(`${prefix}-cat-color`).value;
    document.getElementById(`${prefix}-cat-color-hex`).textContent = color;
    if (prefix === 'add') {
        const icon = document.getElementById('add-cat-icon').value || 'fa-book';
        document.getElementById('add-preview-icon').style.background = color + '22';
        document.getElementById('add-preview-i').className = `fa-solid ${icon} text-lg`;
        document.getElementById('add-preview-i').style.color = color;
        const name = document.getElementById('add-cat-name').value || 'Category Preview';
        document.getElementById('add-preview-name').textContent = name;
    }
}

document.getElementById('add-cat-name')?.addEventListener('input', function() {
    document.getElementById('add-preview-name').textContent = this.value || 'Category Preview';
});
document.getElementById('add-cat-icon')?.addEventListener('input', function() {
    const icon = this.value || 'fa-book';
    document.getElementById('add-preview-i').className = `fa-solid ${icon} text-lg`;
});

function openEditCat(id, name, color, icon) {
    document.getElementById('edit-cat-id').value = id;
    document.getElementById('edit-cat-name').value = name;
    document.getElementById('edit-cat-color').value = color;
    document.getElementById('edit-cat-color-hex').textContent = color;
    document.getElementById('edit-cat-icon').value = icon;
    toggleModal('editCatModal');
}

async function handleAddCat() {
    const name  = document.getElementById('add-cat-name').value.trim();
    const color = document.getElementById('add-cat-color').value;
    const icon  = document.getElementById('add-cat-icon').value.trim() || 'fa-book';
    if (!name) { showToast('Category name is required', 'warning'); return; }
    try {
        const res  = await fetch('/api/categories', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ name, color, icon }) });
        const data = await res.json();
        if (data.success) { showToast('Category added!', 'success'); setTimeout(() => location.reload(), 900); }
        else { showToast(data.message || 'Error', 'error'); }
    } catch { showToast('Network error', 'error'); }
}

async function handleEditCat() {
    const id    = document.getElementById('edit-cat-id').value;
    const name  = document.getElementById('edit-cat-name').value.trim();
    const color = document.getElementById('edit-cat-color').value;
    const icon  = document.getElementById('edit-cat-icon').value.trim() || 'fa-book';
    try {
        const res  = await fetch(`/api/categories/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ name, color, icon }) });
        const data = await res.json();
        if (data.success) { showToast('Category updated!', 'success'); setTimeout(() => location.reload(), 900); }
        else { showToast(data.message || 'Error', 'error'); }
    } catch { showToast('Network error', 'error'); }
}

async function deleteCat(id, name) {
    if (!confirm(`Delete category "${name}"?`)) return;
    try {
        const res  = await fetch(`/api/categories/${id}`, { method:'DELETE' });
        const data = await res.json();
        if (data.success) { showToast('Category deleted', 'info'); setTimeout(() => location.reload(), 900); }
        else { showToast(data.message || 'Error', 'error'); }
    } catch { showToast('Network error', 'error'); }
}

async function seedCategories() {
    try {
        const res  = await fetch('/api/categories/seed', { method:'POST' });
        const data = await res.json();
        if (data.success) { showToast('🎉 Default categories added!', 'success'); setTimeout(() => location.reload(), 1000); }
        else { showToast(data.message, 'info'); }
    } catch { showToast('Network error', 'error'); }
}
</script>

<%- include('../partials/footer') %>
