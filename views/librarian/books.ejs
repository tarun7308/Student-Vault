<%- include('../partials/header', { title: 'Manage Books – StudentVault' }) %>

<div class="flex h-screen w-full overflow-hidden">
<%- include('../partials/sidebar', { role, path }) %>
<div class="flex-1 flex flex-col overflow-hidden">
<%- include('../partials/navbar', { role }) %>

<main class="flex-1 overflow-y-auto p-5 sm:p-7" style="background: var(--bg-primary);">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-7">
        <div>
            <h1 class="text-2xl font-extrabold" style="color: var(--text-primary);">Manage Books</h1>
            <p class="text-sm mt-1" style="color: var(--text-muted);">
                Add, edit and monitor the library's book inventory · <strong><%= books ? books.length : 0 %></strong> books total
            </p>
        </div>
        <div class="flex gap-3 flex-wrap">
            <!-- Search -->
            <div class="flex items-center rounded-xl px-4 py-2.5 gap-3 w-full sm:w-64" style="background: var(--bg-card); border: 1.5px solid var(--border);">
                <i class="fa-solid fa-search text-sm" style="color: var(--text-muted);"></i>
                <input type="text" id="bookSearch" oninput="filterTable()" placeholder="Search books…"
                    class="bg-transparent border-none outline-none text-sm flex-1" style="color: var(--text-primary); font-family: Outfit, sans-serif;">
            </div>
            <button onclick="toggleModal('addBookModal')" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-plus"></i> Add Book
            </button>
        </div>
    </div>

    <!-- Books Table -->
    <div class="sv-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="sv-table" id="booksTable">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>Category</th>
                        <th>Copies</th>
                        <th>Availability</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (books && books.length > 0) { %>
                        <% const spineColors = ['#3b82f6','#8b5cf6','#ec4899','#f59e0b','#10b981','#ef4444','#14b8a6','#f97316','#6366f1','#0ea5e9'];
                           books.forEach((book, idx) => {
                            const color = spineColors[idx % spineColors.length];
                            const pct = book.totalCopies > 0 ? Math.round((book.availableCopies / book.totalCopies) * 100) : 0;
                        %>
                        <tr data-title="<%= book.title.toLowerCase() %>" data-author="<%= book.author.toLowerCase() %>" data-category="<%= (book.category||'').toLowerCase() %>">
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-12 rounded flex items-center justify-center flex-shrink-0 shadow"
                                        style="background: linear-gradient(135deg,<%= color %>cc,<%= color %>66); border-left: 3px solid rgba(0,0,0,0.15);">
                                        <span class="text-white font-extrabold text-sm"><%= book.title.charAt(0) %></span>
                                    </div>
                                    <div>
                                        <p class="font-bold text-sm" style="color: var(--text-primary);"><%= book.title %></p>
                                        <p class="text-xs" style="color: var(--text-muted);">by <%= book.author %></p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="sv-badge sv-badge-blue text-xs"><%= book.category %></span>
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <span class="text-sm font-semibold" style="color: var(--text-primary);"><%= book.availableCopies %></span>
                                    <span class="text-xs" style="color: var(--text-muted);">/ <%= book.totalCopies %></span>
                                </div>
                                <!-- Mini progress bar -->
                                <div class="mt-1 h-1.5 rounded-full overflow-hidden w-20" style="background: var(--border);">
                                    <div class="h-full rounded-full transition-all"
                                        style="width:<%= pct %>%; background: <%= pct > 60 ? '#10b981' : pct > 20 ? '#f59e0b' : '#ef4444' %>;"></div>
                                </div>
                            </td>
                            <td>
                                <% if (book.availableCopies > 0) { %>
                                    <span class="sv-badge sv-badge-green">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                                        Available
                                    </span>
                                <% } else { %>
                                    <span class="sv-badge sv-badge-red">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500 inline-block"></span>
                                        Out of Stock
                                    </span>
                                <% } %>
                            </td>
                            <td class="text-right">
                                <button onclick="openEditModal('<%= book._id %>', '<%= book.title.replace(/'/g, `\\'`) %>', '<%= book.author.replace(/'/g, `\\'`) %>', '<%= book.category %>', <%= book.totalCopies %>, '<%= (book.description || '').replace(/'/g, `\\'`).replace(/\n/g, ' ') %>')"
                                    class="w-8 h-8 rounded-lg inline-flex items-center justify-center mr-2 transition-all hover:scale-110"
                                    style="background: #dbeafe; color: #1d4ed8;" title="Edit">
                                    <i class="fa-solid fa-pen text-xs"></i>
                                </button>
                                <button onclick="deleteBook('<%= book._id %>')"
                                    class="w-8 h-8 rounded-lg inline-flex items-center justify-center transition-all hover:scale-110"
                                    style="background: #fee2e2; color: #dc2626;" title="Delete">
                                    <i class="fa-solid fa-trash text-xs"></i>
                                </button>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="py-16 text-center">
                                <i class="fa-solid fa-books text-5xl mb-4 block" style="color: var(--border);"></i>
                                <p class="font-semibold" style="color: var(--text-muted);">No books in the library yet</p>
                                <button onclick="toggleModal('addBookModal')" class="sv-btn sv-btn-primary mt-4 mx-auto">
                                    <i class="fa-solid fa-plus"></i> Add First Book
                                </button>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</main>
</div>
</div>

<!-- ADD BOOK MODAL -->
<div id="addBookModal" class="sv-modal-overlay">
    <div class="sv-modal w-full max-w-xl">
        <div class="sv-modal-header">
            <div>
                <h3 class="text-lg font-bold" style="color: var(--text-primary);">Add New Book</h3>
                <p class="text-xs mt-0.5" style="color: var(--text-muted);">Fill in the book details below</p>
            </div>
            <button onclick="toggleModal('addBookModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--bg-primary); color: var(--text-muted);">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form id="addBookForm" class="sv-modal-body space-y-4" onsubmit="handleAddBook(event)">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label class="sv-label">Book Title <span class="text-red-500">*</span></label>
                    <input type="text" id="add-title" required class="sv-input" placeholder="e.g. Introduction to Algorithms">
                </div>
                <div>
                    <label class="sv-label">Author <span class="text-red-500">*</span></label>
                    <input type="text" id="add-author" required class="sv-input" placeholder="e.g. Thomas H. Cormen">
                </div>
                <div>
                    <label class="sv-label">Category <span class="text-red-500">*</span></label>
                    <select id="add-category" class="sv-input bg-inherit">
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                            <option value="<%= cat.name %>"><%= cat.name %></option>
                            <% }) %>
                        <% } else { %>
                            <option value="Computer Science">Computer Science</option>
                            <option value="Mathematics">Mathematics</option>
                            <option value="Physics">Physics</option>
                            <option value="Chemistry">Chemistry</option>
                            <option value="Literature">Literature</option>
                            <option value="Other">Other</option>
                        <% } %>
                    </select>
                </div>
                <div>
                    <label class="sv-label">Total Copies <span class="text-red-500">*</span></label>
                    <input type="number" id="add-copies" min="1" value="1" required class="sv-input">
                </div>
                <div class="sm:col-span-2">
                    <label class="sv-label">Description <span class="text-xs font-normal" style="color: var(--text-muted);">(optional)</span></label>
                    <textarea id="add-description" rows="3" class="sv-input resize-none" placeholder="Brief description of the book…"></textarea>
                </div>
            </div>
        </form>
        <div class="sv-modal-footer">
            <button type="button" onclick="toggleModal('addBookModal')" class="sv-btn sv-btn-secondary">Cancel</button>
            <button type="button" onclick="handleAddBook()" id="addBookBtn" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-plus"></i> Add Book
            </button>
        </div>
    </div>
</div>

<!-- EDIT BOOK MODAL -->
<div id="editBookModal" class="sv-modal-overlay">
    <div class="sv-modal w-full max-w-xl">
        <div class="sv-modal-header">
            <div>
                <h3 class="text-lg font-bold" style="color: var(--text-primary);">Edit Book</h3>
                <p class="text-xs mt-0.5" style="color: var(--text-muted);">Update the book details</p>
            </div>
            <button onclick="toggleModal('editBookModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--bg-primary); color: var(--text-muted);">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="sv-modal-body space-y-4">
            <input type="hidden" id="edit-id">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label class="sv-label">Book Title</label>
                    <input type="text" id="edit-title" class="sv-input">
                </div>
                <div>
                    <label class="sv-label">Author</label>
                    <input type="text" id="edit-author" class="sv-input">
                </div>
                <div>
                    <label class="sv-label">Category</label>
                    <select id="edit-category" class="sv-input bg-inherit">
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                            <option value="<%= cat.name %>"><%= cat.name %></option>
                            <% }) %>
                        <% } else { %>
                            <option value="Computer Science">Computer Science</option>
                            <option value="Mathematics">Mathematics</option>
                            <option value="Physics">Physics</option>
                            <option value="Chemistry">Chemistry</option>
                            <option value="Literature">Literature</option>
                            <option value="Other">Other</option>
                        <% } %>
                    </select>
                </div>
                <div>
                    <label class="sv-label">Total Copies</label>
                    <input type="number" id="edit-copies" min="1" class="sv-input">
                </div>
                <div class="sm:col-span-2">
                    <label class="sv-label">Description</label>
                    <textarea id="edit-description" rows="3" class="sv-input resize-none"></textarea>
                </div>
            </div>
        </div>
        <div class="sv-modal-footer">
            <button type="button" onclick="toggleModal('editBookModal')" class="sv-btn sv-btn-secondary">Cancel</button>
            <button type="button" onclick="handleEditBook()" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
        </div>
    </div>
</div>

<script>
function filterTable() {
    const search = document.getElementById('bookSearch').value.toLowerCase();
    document.querySelectorAll('#booksTable tbody tr[data-title]').forEach(row => {
        const match = row.dataset.title.includes(search) || row.dataset.author.includes(search);
        row.style.display = match ? '' : 'none';
    });
}

function openEditModal(id, title, author, category, copies, description) {
    document.getElementById('edit-id').value = id;
    document.getElementById('edit-title').value = title;
    document.getElementById('edit-author').value = author;
    document.getElementById('edit-category').value = category;
    document.getElementById('edit-copies').value = copies;
    document.getElementById('edit-description').value = description;
    toggleModal('editBookModal');
}

async function handleAddBook() {
    const btn = document.getElementById('addBookBtn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Adding…';
    btn.disabled = true;
    const payload = {
        title: document.getElementById('add-title').value,
        author: document.getElementById('add-author').value,
        category: document.getElementById('add-category').value,
        totalCopies: document.getElementById('add-copies').value,
        description: document.getElementById('add-description').value
    };
    try {
        const res  = await fetch('/api/books', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        const data = await res.json();
        if (data.success) {
            showToast('📚 Book added successfully!', 'success');
            setTimeout(() => window.location.reload(), 900);
        } else {
            showToast(data.message || 'Error adding book', 'error');
            btn.innerHTML = '<i class="fa-solid fa-plus"></i> Add Book'; btn.disabled = false;
        }
    } catch { showToast('Network error', 'error'); btn.innerHTML = '<i class="fa-solid fa-plus"></i> Add Book'; btn.disabled = false; }
}

async function handleEditBook() {
    const id = document.getElementById('edit-id').value;
    const payload = {
        title: document.getElementById('edit-title').value,
        author: document.getElementById('edit-author').value,
        category: document.getElementById('edit-category').value,
        totalCopies: document.getElementById('edit-copies').value,
        description: document.getElementById('edit-description').value
    };
    try {
        const res  = await fetch(`/api/books/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        const data = await res.json();
        if (data.success) {
            showToast('✅ Book updated!', 'success');
            setTimeout(() => window.location.reload(), 900);
        } else { showToast(data.message || 'Error updating book', 'error'); }
    } catch { showToast('Network error', 'error'); }
}

async function deleteBook(id) {
    if (!confirm('Delete this book? This cannot be undone.')) return;
    try {
        const res  = await fetch(`/api/books/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
            showToast('Book deleted.', 'info');
            setTimeout(() => window.location.reload(), 900);
        } else { showToast(data.message || 'Error deleting book', 'error'); }
    } catch { showToast('Network error', 'error'); }
}

// ── Filter by search text AND active category ─────────────────────────────────
let activeCategoryFilter = '';

function filterTable() {
    const q   = document.getElementById('bookSearch').value.toLowerCase();
    document.querySelectorAll('#booksTable tbody tr[data-title]').forEach(row => {
        const matchSearch   = row.dataset.title.includes(q) || row.dataset.author.includes(q);
        const matchCategory = !activeCategoryFilter || row.dataset.category === activeCategoryFilter;
        row.style.display   = (matchSearch && matchCategory) ? '' : 'none';
    });
    // update visible count
    const visible = document.querySelectorAll('#booksTable tbody tr[data-title]:not([style*="none"])').length;
    const el = document.getElementById('visible-count');
    if (el) el.textContent = visible;
}

// Auto-apply ?category= or ?search= from URL on load
(function applyUrlCategory() {
    const params = new URLSearchParams(window.location.search);
    const cat    = params.get('category');
    const searchVal = params.get('search') || params.get('q');
    
    if (cat) {
        activeCategoryFilter = cat.toLowerCase();
        // show a dismissible banner
        const banner = document.createElement('div');
        banner.innerHTML = `
            <div class="flex items-center justify-between px-5 py-3 mb-4 rounded-xl"
                style="background:#dbeafe; border:1.5px solid #bfdbfe; color:#1d4ed8;">
                <span class="text-sm font-semibold">
                    <i class="fa-solid fa-filter mr-2"></i>
                    Filtering by category: <strong>${cat}</strong>
                </span>
                <button onclick="clearCategoryFilter()" class="text-xs font-bold px-3 py-1 rounded-lg"
                    style="background:#1d4ed8; color:white;">✕ Clear Filter</button>
            </div>`;
        document.querySelector('main').insertBefore(banner, document.querySelector('main').children[1]);
    }
    
    if (searchVal) {
        const bookSearch = document.getElementById('bookSearch');
        if (bookSearch) {
            bookSearch.value = searchVal;
        }
    }
    
    if (cat || searchVal) {
        filterTable();
    }
})();

function clearCategoryFilter() {
    activeCategoryFilter = '';
    window.history.replaceState({}, '', '/librarian/books');
    filterTable();
    document.querySelector('main').children[1]?.remove();
}
</script>

<%- include('../partials/footer') %>
