<%- include('../partials/header', { title: 'Browse Books – StudentVault' }) %>

<style>
.book-card { transition: transform 0.25s, box-shadow 0.25s; }
.book-card:hover { transform: translateY(-6px); }
.filter-pill {
    padding: 6px 16px; border-radius: 999px; font-size: 0.82rem;
    font-weight: 600; cursor: pointer; border: 1.5px solid var(--border);
    background: var(--bg-card); color: var(--text-muted);
    transition: all 0.2s;
}
.filter-pill:hover { border-color: var(--accent); color: var(--accent); }
.filter-pill.active {
    background: linear-gradient(135deg,#1485e0,#0e3a5e);
    color: white; border-color: transparent;
    box-shadow: 0 4px 12px rgba(20,133,224,0.3);
}
</style>

<div class="flex h-screen w-full overflow-hidden">
<%- include('../partials/sidebar', { role, path }) %>
<div class="flex-1 flex flex-col overflow-hidden">
<%- include('../partials/navbar', { role }) %>

<main class="flex-1 overflow-y-auto p-5 sm:p-7" style="background: var(--bg-primary);">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-extrabold" style="color: var(--text-primary);">Browse Books</h1>
            <p class="text-sm mt-1" style="color: var(--text-muted);">
                Discover and request from the university collection · <strong><%= books ? books.length : 0 %></strong> books available
            </p>
        </div>
        <!-- Search -->
        <div class="flex items-center rounded-xl px-4 py-2.5 gap-3 w-full sm:w-80 flex-shrink-0"
            style="background: var(--bg-card); border: 1.5px solid var(--border);">
            <i class="fa-solid fa-search text-sm" style="color: var(--text-muted);"></i>
            <input type="text" id="searchInput" oninput="filterBooks()" placeholder="Search title, author, category…"
                class="bg-transparent border-none outline-none text-sm flex-1" style="color: var(--text-primary); font-family: Outfit, sans-serif;">
        </div>
    </div>

    <!-- Category Filter Pills (dynamic from DB) -->
    <div class="flex flex-wrap gap-2 mb-7">
        <button class="filter-pill active" onclick="setFilter(this, 'All')">
            <i class="fa-solid fa-border-all mr-1"></i>All
        </button>
        <% if (categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
            <button class="filter-pill" onclick="setFilter(this, '<%= cat.name %>')"
                style="--cat-color: <%= cat.color %>;">
                <i class="fa-solid <%= cat.icon %> mr-1" style="color:<%= cat.color %>;"></i><%= cat.name %>
            </button>
            <% }) %>
        <% } %>
    </div>


    <!-- Book Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="booksGrid">
        <% const spineColors = [
            'linear-gradient(135deg,#3b82f6,#1d4ed8)',
            'linear-gradient(135deg,#8b5cf6,#6d28d9)',
            'linear-gradient(135deg,#ec4899,#be185d)',
            'linear-gradient(135deg,#f59e0b,#d97706)',
            'linear-gradient(135deg,#10b981,#059669)',
            'linear-gradient(135deg,#ef4444,#dc2626)',
            'linear-gradient(135deg,#14b8a6,#0d9488)',
            'linear-gradient(135deg,#f97316,#ea580c)',
            'linear-gradient(135deg,#6366f1,#4f46e5)',
            'linear-gradient(135deg,#0ea5e9,#0284c7)'
        ]; %>

        <% if (books && books.length > 0) { %>
            <% books.forEach((book, idx) => {
                const color = spineColors[idx % spineColors.length];
                const firstLetter = book.title.charAt(0).toUpperCase();
            %>
            <div class="book-card sv-card overflow-hidden flex flex-col"
                data-title="<%= book.title.toLowerCase() %>"
                data-author="<%= book.author.toLowerCase() %>"
                data-category="<%= book.category.toLowerCase() %>">

                <!-- Book Visual Cover -->
                <div class="relative h-44 flex items-center justify-center overflow-hidden"
                    style="background: <%= color %>;">
                    <div class="absolute left-0 top-0 bottom-0 w-3 bg-black/20 flex-shrink-0"></div>
                    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);"></div>
                    <div class="text-center z-10 px-4">
                        <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mx-auto mb-2">
                            <span class="text-3xl font-extrabold text-white"><%= firstLetter %></span>
                        </div>
                        <p class="text-white/80 text-xs font-semibold uppercase tracking-wider"><%= book.category %></p>
                    </div>
                    <!-- QR Button -->
                    <button onclick="showQR('<%= book._id %>', '<%= book.title.replace(/'/g, `\\'`) %>')"
                        class="absolute top-2 left-2 w-7 h-7 rounded-md flex items-center justify-center bg-white/20 hover:bg-white/30 transition-all"
                        title="View QR Code">
                        <i class="fa-solid fa-qrcode text-white text-xs"></i>
                    </button>
                    <!-- Availability Badge -->
                    <% if (book.availableCopies > 0) { %>
                    <div class="absolute top-2 right-2 bg-emerald-500 text-white text-xs font-bold px-2 py-0.5 rounded-full shadow-md">
                        ✓ Available
                    </div>
                    <% } else { %>
                    <div class="absolute top-2 right-2 bg-black/50 text-white text-xs font-bold px-2 py-0.5 rounded-full">
                        Out of Stock
                    </div>
                    <% } %>
                </div>

                <!-- Book Info -->
                <div class="p-4 flex-1 flex flex-col">
                    <h3 class="font-bold text-base leading-snug mb-0.5 line-clamp-2" style="color: var(--text-primary);"><%= book.title %></h3>
                    <p class="text-sm mb-2" style="color: var(--text-muted);">by <%= book.author %></p>

                    <!-- Star Rating -->
                    <div class="flex items-center gap-1.5 mb-2">
                        <% const avg = book.averageRating || 0;
                           for (let s = 1; s <= 5; s++) { %>
                        <i class="fa-<%= s <= Math.round(avg) ? 'solid' : 'regular' %> fa-star text-xs"
                            style="color: <%= s <= Math.round(avg) ? '#f59e0b' : 'var(--border)' %>;"></i>
                        <% } %>
                        <span class="text-xs font-semibold ml-1" style="color: var(--text-muted);">
                            <%= avg > 0 ? avg.toFixed(1) : 'No reviews' %>
                            <% if (book.numReviews > 0) { %> (<%= book.numReviews %>)<% } %>
                        </span>
                    </div>

                    <div class="flex items-center gap-2 mb-3">
                        <span class="sv-badge sv-badge-blue text-xs"><%= book.category %></span>
                        <span class="text-xs" style="color: var(--text-muted);"><%= book.availableCopies %>/<%= book.totalCopies %> copies</span>
                    </div>

                    <div class="mt-auto space-y-2">
                        <% if (book.availableCopies > 0) { %>
                        <button onclick="requestBook('<%= book._id %>')"
                            class="sv-btn sv-btn-primary w-full justify-center py-2.5 text-sm">
                            <i class="fa-solid fa-hand-holding-heart"></i> Request Issue
                        </button>
                        <% } else { %>
                        <button disabled
                            class="w-full py-2.5 rounded-xl text-sm font-semibold cursor-not-allowed"
                            style="background: var(--bg-primary); color: var(--text-muted); border: 1.5px solid var(--border);">
                            <i class="fa-solid fa-ban mr-1"></i> Unavailable
                        </button>
                        <% } %>
                        <!-- Rate button (only shown inline, handled by modal) -->
                        <% if (book.myReview) { %>
                        <button onclick="openRateModal('<%= book._id %>', <%= book.myReview.rating %>, '<%= (book.myReview.comment||'').replace(/'/g, `\\'`) %>')"
                            class="w-full py-2 rounded-xl text-xs font-semibold text-center transition-all hover:opacity-80"
                            style="background: #fef3c7; color: #92400e;">
                            <i class="fa-solid fa-star text-amber-500 mr-1"></i> Your Rating: <%= book.myReview.rating %>/5
                        </button>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full text-center py-20">
                <i class="fa-solid fa-books text-6xl mb-4 block" style="color: var(--border);"></i>
                <p class="text-lg font-semibold" style="color: var(--text-muted);">No books found</p>
                <p class="text-sm mt-1" style="color: var(--text-muted);">The librarian hasn't added books yet.</p>
            </div>
        <% } %>
    </div>

    <!-- No results msg -->
    <div id="noResults" class="hidden text-center py-16">
        <i class="fa-solid fa-magnifying-glass text-5xl mb-4 block" style="color: var(--border);"></i>
        <p class="text-lg font-semibold" style="color: var(--text-muted);">No books match your search</p>
    </div>

</main>
</div>
</div>

<!-- QR Code Modal -->
<div id="qrModal" class="sv-modal-overlay">
    <div class="sv-modal max-w-xs text-center">
        <div class="sv-modal-header">
            <h3 class="text-base font-bold" style="color: var(--text-primary);">
                <i class="fa-solid fa-qrcode mr-2 text-brand-500"></i>Book QR Code
            </h3>
            <button onclick="toggleModal('qrModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--bg-primary); color: var(--text-muted);">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="sv-modal-body flex flex-col items-center gap-4">
            <div id="qr-img-wrap" class="p-3 rounded-xl" style="background: white; border: 1.5px solid var(--border);">
                <img id="qr-img" src="" alt="QR Code" class="w-48 h-48 rounded-lg">
            </div>
            <p id="qr-title" class="font-bold text-sm text-center" style="color: var(--text-primary);"></p>
            <p class="text-xs text-center" style="color: var(--text-muted);">Scan to view book details or use for library check-in.</p>
        </div>
        <div class="sv-modal-footer justify-center">
            <a id="qr-download" download="qrcode.png" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-download"></i> Download QR
            </a>
            <button onclick="toggleModal('qrModal')" class="sv-btn sv-btn-secondary">Close</button>
        </div>
    </div>
</div>

<!-- Review Modal -->
<div id="reviewModal" class="sv-modal-overlay">
    <div class="sv-modal max-w-md">
        <div class="sv-modal-header">
            <h3 class="text-base font-bold" style="color: var(--text-primary);">
                <i class="fa-solid fa-star mr-2 text-amber-400"></i>Rate this Book
            </h3>
            <button onclick="toggleModal('reviewModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--bg-primary); color: var(--text-muted);">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="sv-modal-body space-y-5">
            <input type="hidden" id="review-book-id">
            <!-- Star Picker -->
            <div class="text-center">
                <p class="text-sm font-semibold mb-3" style="color: var(--text-secondary);">Tap stars to rate</p>
                <div class="flex justify-center gap-2" id="star-picker">
                    <% for (let s = 1; s <= 5; s++) { %>
                    <button type="button" onclick="setStarRating(<%= s %>)"
                        id="star-<%= s %>"
                        class="w-10 h-10 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                        style="background: var(--bg-primary);">
                        <i class="fa-regular fa-star text-2xl text-amber-400"></i>
                    </button>
                    <% } %>
                </div>
                <p id="star-label" class="text-sm font-bold mt-2" style="color: var(--text-muted);">Select a rating</p>
            </div>
            <input type="hidden" id="review-rating" value="0">
            <div>
                <label class="sv-label">Your Review <span class="text-xs font-normal" style="color: var(--text-muted);">(optional)</span></label>
                <textarea id="review-comment" rows="3" class="sv-input resize-none"
                    placeholder="Share your thoughts about this book…"></textarea>
            </div>
        </div>
        <div class="sv-modal-footer">
            <button onclick="toggleModal('reviewModal')" class="sv-btn sv-btn-secondary">Cancel</button>
            <button onclick="submitReview()" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-paper-plane"></i> Submit Review
            </button>
        </div>
    </div>
</div>

<script>
let activeCategoryFilter = 'All';

function setFilter(btn, category) {
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    activeCategoryFilter = category;
    filterBooks();
}

function filterBooks() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const cards  = document.querySelectorAll('#booksGrid [data-title]');
    let visible = 0;
    cards.forEach(card => {
        const title    = card.dataset.title || '';
        const author   = card.dataset.author || '';
        const category = card.dataset.category || '';
        const matchCat = activeCategoryFilter === 'All' || category === activeCategoryFilter.toLowerCase();
        const matchSrch = !search || title.includes(search) || author.includes(search) || category.includes(search);
        if (matchCat && matchSrch) { card.style.display = ''; visible++; }
        else { card.style.display = 'none'; }
    });
    document.getElementById('noResults').classList.toggle('hidden', visible > 0);
}

async function requestBook(id) {
    try {
        const res = await fetch('/api/issues/request', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ bookId: id })
        });
        const data = await res.json();
        if (data.success) {
            showToast('📚 Request submitted!', 'success');
            setTimeout(() => window.location.reload(), 1200);
        } else {
            showToast(data.message || 'Failed to request book', 'error');
        }
    } catch (err) {
        showToast('Network error', 'error');
    }
}

// ── QR Code ──────────────────────────────────────────────────────────────
function showQR(bookId, title) {
    const url = `${window.location.origin}/student/browse?book=${bookId}`;
    const qrSrc = `https://api.qrserver.com/v1/create-qr-code/?size=192x192&data=${encodeURIComponent(url)}&color=0e3a5e&bgcolor=ffffff&margin=10`;
    document.getElementById('qr-img').src = qrSrc;
    document.getElementById('qr-title').textContent = title;
    document.getElementById('qr-download').href = qrSrc;
    document.getElementById('qr-download').download = `${title.replace(/\s+/g,'-')}-qr.png`;
    toggleModal('qrModal');
}

// ── Star Rating & Review ─────────────────────────────────────────────────
const starLabels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
let currentStarRating = 0;

function openRateModal(bookId, existingRating = 0, existingComment = '') {
    document.getElementById('review-book-id').value = bookId;
    document.getElementById('review-comment').value = existingComment;
    currentStarRating = existingRating;
    renderStars(existingRating);
    toggleModal('reviewModal');
}

function setStarRating(val) {
    currentStarRating = val;
    document.getElementById('review-rating').value = val;
    renderStars(val);
}

function renderStars(val) {
    for (let s = 1; s <= 5; s++) {
        const btn = document.getElementById(`star-${s}`);
        const icon = btn.querySelector('i');
        if (s <= val) {
            icon.className = 'fa-solid fa-star text-2xl text-amber-400';
            btn.style.background = '#fef3c7';
        } else {
            icon.className = 'fa-regular fa-star text-2xl text-amber-400';
            btn.style.background = 'var(--bg-primary)';
        }
    }
    document.getElementById('star-label').textContent = val > 0 ? starLabels[val] : 'Select a rating';
    document.getElementById('star-label').style.color = val > 0 ? '#d97706' : 'var(--text-muted)';
}

async function submitReview() {
    const bookId  = document.getElementById('review-book-id').value;
    const rating  = currentStarRating;
    const comment = document.getElementById('review-comment').value.trim();
    if (!rating) { showToast('Please select a star rating', 'warning'); return; }
    try {
        const res  = await fetch('/api/reviews', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ bookId, rating, comment })
        });
        const data = await res.json();
        if (data.success) {
            showToast('⭐ Review submitted!', 'success');
            toggleModal('reviewModal');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            showToast(data.message || 'Could not submit review', 'error');
        }
    } catch { showToast('Network error', 'error'); }
}

// Auto-apply search from URL on load
(function() {
    const params = new URLSearchParams(window.location.search);
    const searchVal = params.get('search') || params.get('q');
    if (searchVal) {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.value = searchVal;
            filterBooks();
        }
    }
})();
</script>

<%- include('../partials/footer') %>
