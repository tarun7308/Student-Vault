<%- include('../partials/header', { title: 'My Books – StudentVault' }) %>
<div class="flex h-screen w-full overflow-hidden">
<%- include('../partials/sidebar', { role, path }) %>
<div class="flex-1 flex flex-col overflow-hidden">
<%- include('../partials/navbar', { role }) %>
<main class="flex-1 overflow-y-auto p-5 sm:p-7" style="background:var(--bg-primary);">

  <!-- Header + Fine Banner -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-7">
    <div>
      <h1 class="text-2xl font-extrabold" style="color:var(--text-primary);">My Books</h1>
      <p class="text-sm mt-1" style="color:var(--text-muted);">Manage your active issues and review returned books.</p>
    </div>
    <% if (totalFines > 0) { %>
    <div class="flex items-center gap-3 px-4 py-3 rounded-xl" style="background:#fee2e2; border:1.5px solid #fecaca;">
      <i class="fa-solid fa-triangle-exclamation text-red-500"></i>
      <div>
        <p class="font-bold text-sm text-red-700">Total Fines Due</p>
        <p class="text-xl font-extrabold text-red-600">₹<%= totalFines.toFixed(0) %></p>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Active Issues -->
  <% const spineColors=['#3b82f6','#8b5cf6','#ec4899','#f59e0b','#10b981','#ef4444','#14b8a6','#f97316','#6366f1','#84cc16']; %>
  <h2 class="text-base font-bold mb-4" style="color:var(--text-primary);">
    <i class="fa-solid fa-book-open mr-2 text-blue-500"></i>Currently Issued
    <span class="sv-badge sv-badge-blue ml-2"><%= issuedBooks.length %></span>
  </h2>

  <% if (issuedBooks && issuedBooks.length > 0) { %>
  <div class="space-y-4 mb-8">
    <% issuedBooks.forEach((ib, idx) => {
        const color = spineColors[idx % spineColors.length];
        const isOverdue = now > ib.dueDate;
        const diffDays  = Math.ceil(Math.abs(now - ib.dueDate) / 86400000);
        const fine      = isOverdue ? diffDays : 0;
        const renewsLeft = ib.maxRenewals - (ib.renewalCount || 0);
    %>
    <div class="sv-card p-5 flex flex-col sm:flex-row sm:items-center gap-5"
      style="<%= isOverdue ? 'border-left:4px solid #ef4444;' : '' %>">

      <!-- Book Spine -->
      <div class="w-14 h-20 rounded-md flex items-center justify-center flex-shrink-0 shadow-md"
        style="background:linear-gradient(135deg,<%=color%>cc,<%=color%>55); border-left:4px solid rgba(0,0,0,0.15);">
        <span class="text-white font-extrabold text-2xl"><%= ib.book.title.charAt(0) %></span>
      </div>

      <!-- Info -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <h3 class="font-bold text-base" style="color:var(--text-primary);"><%= ib.book.title %></h3>
          <span class="sv-badge sv-badge-blue text-xs"><%= ib.book.category %></span>
          <% if (ib.renewalCount > 0) { %>
          <span class="sv-badge sv-badge-green text-xs">Renewed ×<%= ib.renewalCount %></span>
          <% } %>
        </div>
        <p class="text-sm mb-2" style="color:var(--text-muted);">by <%= ib.book.author %></p>
        <div class="flex flex-wrap gap-4 text-xs" style="color:var(--text-muted);">
          <span><i class="fa-regular fa-calendar mr-1"></i>Issued: <%= new Date(ib.issueDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
          <span style="color:<%=isOverdue?'#dc2626':diffDays<=3?'#d97706':'inherit'%>;">
            <i class="fa-regular fa-clock mr-1"></i>Due: <%= new Date(ib.dueDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
          </span>
          <% if (fine > 0) { %><span class="text-red-500 font-semibold"><i class="fa-solid fa-indian-rupee-sign mr-1"></i>Fine: ₹<%= fine %></span><% } %>
        </div>
      </div>

      <!-- Status + Actions -->
      <div class="flex flex-col items-end gap-2">
        <% if (isOverdue) { %>
        <span class="sv-badge sv-badge-red"><i class="fa-solid fa-triangle-exclamation mr-1"></i>Overdue (<%= diffDays %>d)</span>
        <% } else if (diffDays <= 3) { %>
        <span class="sv-badge sv-badge-amber">Due in <%= diffDays %>d</span>
        <% } else { %>
        <span class="sv-badge sv-badge-blue">Active</span>
        <% } %>

        <div class="flex gap-2 flex-wrap justify-end">
          <% if (renewsLeft > 0) { %>
          <button onclick="renewBook('<%=ib._id%>')"
            class="sv-btn text-xs py-1.5 px-3"
            style="background:#dbeafe; color:#1d4ed8; border:1.5px solid #bfdbfe;"
            title="<%= renewsLeft %> renewal(s) left">
            <i class="fa-solid fa-rotate-right"></i> Renew (<%= renewsLeft %> left)
          </button>
          <% } else { %>
          <span class="text-xs px-3 py-1.5 rounded-lg" style="background:var(--bg-primary); color:var(--text-muted);">No renewals left</span>
          <% } %>
          <!-- Return Book -->
          <button onclick="returnBook('<%=ib._id%>')"
            class="sv-btn text-xs py-1.5 px-3"
            style="background:#fee2e2; color:#dc2626; border:1.5px solid #fecaca;">
            <i class="fa-solid fa-rotate-left"></i> Return Book
          </button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="sv-card p-12 text-center mb-8">
    <i class="fa-solid fa-book text-5xl mb-3 block" style="color:var(--border);"></i>
    <p class="font-semibold" style="color:var(--text-muted);">No books currently issued</p>
    <a href="/student/browse" class="sv-btn sv-btn-primary mt-4 inline-flex">Browse Books</a>
  </div>
  <% } %>

  <!-- Recently Returned — Rate & Review -->
  <% if (returnedBooks && returnedBooks.length > 0) { %>
  <h2 class="text-base font-bold mb-4" style="color:var(--text-primary);">
    <i class="fa-solid fa-star mr-2 text-amber-400"></i>Recently Returned — Rate Them!
    <span class="sv-badge sv-badge-amber ml-2"><%= returnedBooks.length %></span>
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% returnedBooks.forEach((ib, idx) => {
        const color = spineColors[(idx + 5) % spineColors.length];
        const myR   = ib.myReview;
    %>
    <div class="sv-card overflow-hidden hover:-translate-y-1 transition-transform">
      <!-- Mini Spine -->
      <div class="h-20 flex items-center justify-center" style="background:linear-gradient(135deg,<%=color%>cc,<%=color%>44);">
        <span class="text-white font-extrabold text-3xl"><%= ib.book ? ib.book.title.charAt(0) : '?' %></span>
      </div>
      <div class="p-4">
        <p class="font-bold text-sm mb-0.5" style="color:var(--text-primary);"><%= ib.book ? ib.book.title : 'Unknown' %></p>
        <p class="text-xs mb-3" style="color:var(--text-muted);">Returned <%= new Date(ib.returnDate).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></p>

        <!-- Stars display -->
        <div class="flex items-center gap-1 mb-3">
          <% for(let s=1;s<=5;s++) { %>
          <i class="fa-<%=s<=(myR?myR.rating:0)?'solid':'regular'%> fa-star text-xs" style="color:<%=s<=(myR?myR.rating:0)?'#f59e0b':'var(--border)'%>;"></i>
          <% } %>
          <span class="text-xs ml-1" style="color:var(--text-muted);"><%=myR?myR.rating+'/5':'Not rated'%></span>
        </div>

        <% if (myR) { %>
        <button onclick="openRateModal('<%=ib.book._id%>',<%=myR.rating%>,'<%=(myR.comment||'').replace(/'/g,`\\'`)%>')"
          class="w-full py-2 text-xs font-semibold rounded-lg transition-all hover:opacity-80"
          style="background:#fef3c7; color:#92400e;">
          <i class="fa-solid fa-pen mr-1"></i>Edit Your Review
        </button>
        <% } else { %>
        <button onclick="openRateModal('<%=ib.book._id%>',0,'')"
          class="sv-btn sv-btn-primary w-full justify-center py-2 text-xs">
          <i class="fa-solid fa-star"></i> Rate this Book
        </button>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

</main>
</div>
</div>

<!-- Review Modal -->
<div id="reviewModal" class="sv-modal-overlay">
  <div class="sv-modal max-w-md">
    <div class="sv-modal-header">
      <h3 class="text-base font-bold" style="color:var(--text-primary);"><i class="fa-solid fa-star mr-2 text-amber-400"></i>Rate this Book</h3>
      <button onclick="toggleModal('reviewModal')" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:var(--bg-primary);color:var(--text-muted);"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="sv-modal-body space-y-5">
      <input type="hidden" id="review-book-id">
      <div class="text-center">
        <p class="text-sm font-semibold mb-3" style="color:var(--text-secondary);">Tap stars to rate</p>
        <div class="flex justify-center gap-2" id="star-picker">
          <% for(let s=1;s<=5;s++) { %>
          <button type="button" onclick="setStarRating(<%=s%>)" id="star-<%=s%>"
            class="w-10 h-10 rounded-lg flex items-center justify-center transition-all hover:scale-110"
            style="background:var(--bg-primary);">
            <i class="fa-regular fa-star text-2xl text-amber-400"></i>
          </button>
          <% } %>
        </div>
        <p id="star-label" class="text-sm font-bold mt-2" style="color:var(--text-muted);">Select a rating</p>
      </div>
      <input type="hidden" id="review-rating" value="0">
      <div>
        <label class="sv-label">Your Review <span class="text-xs font-normal" style="color:var(--text-muted);">(optional)</span></label>
        <textarea id="review-comment" rows="3" class="sv-input resize-none" placeholder="Share your thoughts…"></textarea>
      </div>
    </div>
    <div class="sv-modal-footer">
      <button onclick="toggleModal('reviewModal')" class="sv-btn sv-btn-secondary">Cancel</button>
      <button onclick="submitReview()" class="sv-btn sv-btn-primary"><i class="fa-solid fa-paper-plane"></i> Submit</button>
    </div>
  </div>
</div>

<script>
async function renewBook(id) {
  try {
    const res  = await fetch(`/api/issues/issued/${id}/renew`, { method:'PUT' });
    const data = await res.json();
    if (data.success) { showToast('🔄 ' + data.message, 'success'); setTimeout(()=>location.reload(),1000); }
    else { showToast(data.message || 'Cannot renew', 'error'); }
  } catch { showToast('Network error','error'); }
}

async function returnBook(id) {
  if (!confirm('Return this book? This action cannot be undone.')) return;
  try {
    const res  = await fetch(`/api/issues/issued/${id}/return`, { method:'PUT' });
    const data = await res.json();
    if (data.success) {
      showToast('✅ Book returned successfully!', 'success');
      setTimeout(()=>location.reload(), 1000);
    } else {
      showToast(data.message || 'Could not return book', 'error');
    }
  } catch { showToast('Network error','error'); }
}

const starLabels = ['','Poor','Fair','Good','Very Good','Excellent'];
let currentStarRating = 0;

function openRateModal(bookId, existingRating=0, existingComment='') {
  document.getElementById('review-book-id').value = bookId;
  document.getElementById('review-comment').value = existingComment;
  currentStarRating = existingRating;
  renderStars(existingRating);
  toggleModal('reviewModal');
}

function setStarRating(val) {
  currentStarRating = val;
  renderStars(val);
}

function renderStars(val) {
  for(let s=1;s<=5;s++){
    const btn=document.getElementById(`star-${s}`);
    const icon=btn.querySelector('i');
    if(s<=val){ icon.className='fa-solid fa-star text-2xl text-amber-400'; btn.style.background='#fef3c7'; }
    else { icon.className='fa-regular fa-star text-2xl text-amber-400'; btn.style.background='var(--bg-primary)'; }
  }
  document.getElementById('star-label').textContent=val>0?starLabels[val]:'Select a rating';
  document.getElementById('star-label').style.color=val>0?'#d97706':'var(--text-muted)';
}

async function submitReview(){
  const bookId=document.getElementById('review-book-id').value;
  const rating=currentStarRating;
  const comment=document.getElementById('review-comment').value.trim();
  if(!rating){showToast('Please select a star rating','warning');return;}
  try{
    const res=await fetch('/api/reviews',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({bookId,rating,comment})});
    const data=await res.json();
    if(data.success){showToast('⭐ Review submitted!','success');toggleModal('reviewModal');setTimeout(()=>location.reload(),1000);}
    else{showToast(data.message||'Error','error');}
  }catch{showToast('Network error','error');}
}
</script>

<%- include('../partials/footer') %>
