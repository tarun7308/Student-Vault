<%- include('../partials/header', { title: 'My Requests – StudentVault' }) %>

<div class="flex h-screen w-full overflow-hidden">
<%- include('../partials/sidebar', { role, path }) %>
<div class="flex-1 flex flex-col overflow-hidden">
<%- include('../partials/navbar', { role }) %>

<main class="flex-1 overflow-y-auto p-5 sm:p-7" style="background: var(--bg-primary);">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-7">
        <div>
            <h1 class="text-2xl font-extrabold" style="color: var(--text-primary);">My Requests</h1>
            <p class="text-sm mt-1" style="color: var(--text-muted);">Track the status of your book borrowing requests.</p>
        </div>
        <a href="/student/request_new" class="sv-btn sv-btn-primary">
            <i class="fa-solid fa-lightbulb"></i> Suggest a Book
        </a>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-4 mb-7">
        <%
            const total    = requests ? requests.length : 0;
            const approved = requests ? requests.filter(r => r.status === 'approved').length : 0;
            const pending  = requests ? requests.filter(r => r.status === 'pending').length : 0;
            const rejected = requests ? requests.filter(r => r.status === 'rejected').length : 0;
        %>
        <div class="sv-card p-4 text-center">
            <p class="text-2xl font-extrabold" style="color: var(--text-primary);"><%= total %></p>
            <p class="text-xs mt-1 font-semibold" style="color: var(--text-muted);">Total Requests</p>
        </div>
        <div class="sv-card p-4 text-center" style="border-left: 3px solid #10b981;">
            <p class="text-2xl font-extrabold text-emerald-500"><%= approved %></p>
            <p class="text-xs mt-1 font-semibold" style="color: var(--text-muted);">Approved</p>
        </div>
        <div class="sv-card p-4 text-center" style="border-left: 3px solid #f59e0b;">
            <p class="text-2xl font-extrabold text-amber-500"><%= pending %></p>
            <p class="text-xs mt-1 font-semibold" style="color: var(--text-muted);">Pending</p>
        </div>
    </div>

    <!-- Requests Table -->
    <div class="sv-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="sv-table">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>Request Date</th>
                        <th>Status</th>
                        <th class="text-right">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (requests && requests.length > 0) { %>
                        <% const spineColors = ['#3b82f6','#8b5cf6','#ec4899','#f59e0b','#10b981','#14b8a6'];
                           requests.forEach((req, i) => {
                            const color = spineColors[i % spineColors.length];
                        %>
                        <tr>
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-12 rounded flex items-center justify-center flex-shrink-0 shadow"
                                        style="background: linear-gradient(135deg,<%= color %>cc,<%= color %>66); border-left: 3px solid rgba(0,0,0,0.15);">
                                        <span class="text-white font-extrabold text-sm"><%= req.book.title.charAt(0) %></span>
                                    </div>
                                    <div>
                                        <p class="font-bold text-sm" style="color: var(--text-primary);"><%= req.book.title %></p>
                                        <p class="text-xs" style="color: var(--text-muted);">by <%= req.book.author %></p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-sm" style="color: var(--text-secondary);">
                                    <%= new Date(req.requestDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
                                </span>
                            </td>
                            <td>
                                <% if (req.status === 'pending') { %>
                                    <span class="sv-badge sv-badge-amber">
                                        <i class="fa-solid fa-hourglass-half"></i> Pending
                                    </span>
                                <% } else if (req.status === 'approved') { %>
                                    <span class="sv-badge sv-badge-green">
                                        <i class="fa-solid fa-circle-check"></i> Approved
                                    </span>
                                <% } else { %>
                                    <span class="sv-badge sv-badge-red">
                                        <i class="fa-solid fa-circle-xmark"></i> Rejected
                                    </span>
                                <% } %>
                            </td>
                            <td class="text-right">
                                <% if (req.status === 'pending') { %>
                                <button onclick="showToast('Cancellation feature coming soon!', 'info')"
                                    class="text-xs font-semibold px-3 py-1.5 rounded-lg transition-all hover:scale-105"
                                    style="color: #dc2626; background: #fee2e2; border: 1px solid #fecaca;">
                                    Cancel
                                </button>
                                <% } else { %>
                                <span class="text-xs" style="color: var(--text-muted);">—</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center py-16">
                                <i class="fa-solid fa-inbox text-4xl mb-3 block" style="color: var(--border);"></i>
                                <p class="font-semibold" style="color: var(--text-muted);">No requests yet</p>
                                <p class="text-xs mt-1" style="color: var(--text-muted);">Browse books and submit a request to get started.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</main>
</div>
</div>

<%- include('../partials/footer') %>
