<%- include('./partials/header', { title: 'My Profile – StudentVault' }) %>

<div class="flex h-screen w-full overflow-hidden">
<%- include('./partials/sidebar', { role, path }) %>
<div class="flex-1 flex flex-col overflow-hidden">
<%- include('./partials/navbar', { role }) %>

<main class="flex-1 overflow-y-auto p-5 sm:p-7" style="background: var(--bg-primary);">

    <!-- Page Header -->
    <div class="mb-7">
        <h1 class="text-2xl font-extrabold" style="color: var(--text-primary);">My Profile</h1>
        <p class="text-sm mt-1" style="color: var(--text-muted);">Manage your account information and security settings</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- ── Left: Profile Card ── -->
        <div class="lg:col-span-1">
            <div class="sv-card p-6 text-center">
                <!-- Avatar -->
                <div class="relative inline-block mb-4">
                    <img id="avatar-preview"
                        src="<%= user.profilePic ? user.profilePic : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=1485e0&color=fff&bold=true&size=128' %>"
                        alt="<%= user.name %>"
                        class="w-28 h-28 rounded-2xl object-cover ring-4 shadow-lg"
                        style="ring-color: var(--accent);">
                    <label for="profilePicInput"
                        class="absolute -bottom-2 -right-2 w-9 h-9 rounded-xl flex items-center justify-center cursor-pointer hover:scale-110 transition-transform shadow-md"
                        style="background: linear-gradient(135deg,#1485e0,#1167b1);"
                        title="Change photo">
                        <i class="fa-solid fa-camera text-white text-sm"></i>
                    </label>
                </div>

                <h2 class="text-xl font-extrabold mt-3" style="color: var(--text-primary);"><%= user.name %></h2>
                <p class="text-sm mt-1" style="color: var(--text-muted);"><%= user.email %></p>

                <span class="inline-flex items-center gap-1.5 mt-3 px-4 py-1 rounded-full text-xs font-bold capitalize
                    <% if (role === 'librarian') { %>sv-badge-purple<% } else { %>sv-badge-blue<% } %>">
                    <i class="fa-solid <% if (role === 'librarian') { %>fa-user-tie<% } else { %>fa-graduation-cap<% } %> text-[10px]"></i>
                    <%= role %>
                </span>

                <div class="mt-5 pt-5 space-y-2 text-left" style="border-top: 1px solid var(--border);">
                    <div class="flex items-center gap-3 p-3 rounded-xl" style="background: var(--bg-primary);">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: #dbeafe;">
                            <i class="fa-solid fa-fingerprint text-blue-600 text-xs"></i>
                        </div>
                        <div class="min-w-0">
                            <p class="text-xs" style="color: var(--text-muted);">User ID</p>
                            <p class="text-xs font-bold font-mono truncate" style="color: var(--text-secondary);">SV-<%= user._id.toString().slice(-8).toUpperCase() %></p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 p-3 rounded-xl" style="background: var(--bg-primary);">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: #d1fae5;">
                            <i class="fa-solid fa-calendar-plus text-emerald-600 text-xs"></i>
                        </div>
                        <div>
                            <p class="text-xs" style="color: var(--text-muted);">Member Since</p>
                            <p class="text-xs font-bold" style="color: var(--text-secondary);"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Right: Edit Forms ── -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Edit Profile Info -->
            <div class="sv-card p-6">
                <div class="flex items-center gap-3 mb-5">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: #dbeafe;">
                        <i class="fa-solid fa-user-pen text-blue-600"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-base" style="color: var(--text-primary);">Personal Information</h3>
                        <p class="text-xs" style="color: var(--text-muted);">Update your name, email, and profile photo</p>
                    </div>
                </div>

                <form id="profile-form" enctype="multipart/form-data" class="space-y-4">
                    <!-- Hidden file input -->
                    <input type="file" id="profilePicInput" name="profilePic" accept="image/*" class="hidden">

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="sv-label" for="profile-name">Full Name</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
                                    <i class="fa-solid fa-user text-xs"></i>
                                </span>
                                <input type="text" id="profile-name" name="name" value="<%= user.name %>"
                                    class="sv-input pl-9" placeholder="Your full name" required>
                            </div>
                        </div>
                        <div>
                            <label class="sv-label" for="profile-email">Email Address</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
                                    <i class="fa-solid fa-envelope text-xs"></i>
                                </span>
                                <input type="email" id="profile-email" name="email" value="<%= user.email %>"
                                    class="sv-input pl-9" placeholder="your@email.com" required>
                            </div>
                        </div>
                    </div>

                    <!-- Profile pic preview bar -->
                    <div id="pic-change-bar" class="hidden items-center gap-3 p-3 rounded-xl" style="background: var(--bg-primary); border: 1.5px dashed var(--border);">
                        <i class="fa-solid fa-image text-brand-500"></i>
                        <p class="text-sm flex-1 truncate" style="color: var(--text-secondary);" id="pic-filename">No file chosen</p>
                        <button type="button" onclick="clearPicChange()" class="text-xs font-semibold text-red-500 hover:opacity-70">Remove</button>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit" id="save-profile-btn" class="sv-btn sv-btn-primary">
                            <i class="fa-solid fa-floppy-disk"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>

            <!-- Change Password -->
            <div class="sv-card p-6">
                <div class="flex items-center gap-3 mb-5">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: #fef3c7;">
                        <i class="fa-solid fa-lock text-amber-600"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-base" style="color: var(--text-primary);">Change Password</h3>
                        <p class="text-xs" style="color: var(--text-muted);">Leave blank to keep your current password</p>
                    </div>
                </div>

                <form id="password-form" class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="sv-label" for="new-password">New Password</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
                                    <i class="fa-solid fa-lock text-xs"></i>
                                </span>
                                <input type="password" id="new-password" name="password"
                                    class="sv-input pl-9 pr-10" placeholder="Min. 6 characters" minlength="6">
                                <button type="button" onclick="togglePwd('new-password','eye1')"
                                    class="absolute right-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
                                    <i id="eye1" class="fa-solid fa-eye text-xs"></i>
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="sv-label" for="confirm-password">Confirm New Password</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
                                    <i class="fa-solid fa-lock text-xs"></i>
                                </span>
                                <input type="password" id="confirm-password"
                                    class="sv-input pl-9 pr-10" placeholder="Repeat new password">
                                <button type="button" onclick="togglePwd('confirm-password','eye2')"
                                    class="absolute right-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
                                    <i id="eye2" class="fa-solid fa-eye text-xs"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Password strength -->
                    <div id="pwd-strength-wrap" class="hidden">
                        <div class="flex gap-1 mb-1">
                            <div id="ps1" class="flex-1 h-1.5 rounded-full transition-all" style="background: var(--border);"></div>
                            <div id="ps2" class="flex-1 h-1.5 rounded-full transition-all" style="background: var(--border);"></div>
                            <div id="ps3" class="flex-1 h-1.5 rounded-full transition-all" style="background: var(--border);"></div>
                            <div id="ps4" class="flex-1 h-1.5 rounded-full transition-all" style="background: var(--border);"></div>
                        </div>
                        <p id="pwd-strength-label" class="text-xs" style="color: var(--text-muted);"></p>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit" id="save-pwd-btn" class="sv-btn sv-btn-primary">
                            <i class="fa-solid fa-key"></i> Update Password
                        </button>
                    </div>
                </form>
            </div>

            <!-- Danger Zone -->
            <div class="sv-card p-6" style="border-left: 4px solid #ef4444;">
                <div class="flex items-start gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#fee2e2;">
                        <i class="fa-solid fa-triangle-exclamation text-red-500 text-sm"></i>
                    </div>
                    <div class="flex-1">
                        <h3 class="font-bold text-base text-red-500">Sign Out</h3>
                        <p class="text-xs mt-1 mb-3" style="color: var(--text-muted);">You will be redirected to the login page.</p>
                        <button onclick="handleLogout()" class="sv-btn sv-btn-danger text-sm">
                            <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>
</div>
</div>

<script>
// ── Profile picture live preview ──────────────────────────────────────────
const picInput = document.getElementById('profilePicInput');
const picBar   = document.getElementById('pic-change-bar');
const picName  = document.getElementById('pic-filename');
const preview  = document.getElementById('avatar-preview');

picInput.addEventListener('change', () => {
    const file = picInput.files[0];
    if (!file) return;
    picName.textContent = file.name;
    picBar.classList.remove('hidden');
    picBar.classList.add('flex');
    const reader = new FileReader();
    reader.onload = e => { preview.src = e.target.result; };
    reader.readAsDataURL(file);
});

function clearPicChange() {
    picInput.value = '';
    picBar.classList.add('hidden');
    picBar.classList.remove('flex');
    // Restore original avatar
    preview.src = "<%= user.profilePic ? user.profilePic : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=1485e0&color=fff&bold=true&size=128' %>";
}

// ── Password visibility toggle ────────────────────────────────────────────
function togglePwd(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa-solid fa-eye-slash text-xs';
    } else {
        input.type = 'password';
        icon.className = 'fa-solid fa-eye text-xs';
    }
}

// ── Password strength meter ───────────────────────────────────────────────
document.getElementById('new-password').addEventListener('input', function() {
    const val = this.value;
    const wrap = document.getElementById('pwd-strength-wrap');
    const label = document.getElementById('pwd-strength-label');
    const bars  = [document.getElementById('ps1'), document.getElementById('ps2'),
                   document.getElementById('ps3'), document.getElementById('ps4')];

    if (!val) { wrap.classList.add('hidden'); return; }
    wrap.classList.remove('hidden');

    let score = 0;
    if (val.length >= 6) score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;

    const colors = ['#ef4444','#f59e0b','#3b82f6','#10b981'];
    const labels = ['Weak','Fair','Good','Strong'];
    bars.forEach((b, i) => {
        b.style.background = i < score ? colors[score - 1] : 'var(--border)';
    });
    label.textContent = 'Strength: ' + (labels[score - 1] || 'Too short');
    label.style.color = colors[score - 1] || 'var(--text-muted)';
});

// ── Save Profile (name, email, profilePic) ────────────────────────────────
document.getElementById('profile-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('save-profile-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving…';

    const formData = new FormData();
    formData.append('name',  document.getElementById('profile-name').value.trim());
    formData.append('email', document.getElementById('profile-email').value.trim());
    if (picInput.files[0]) {
        formData.append('profilePic', picInput.files[0]);
    }

    try {
        const res  = await fetch('/api/users/profile', { method: 'PUT', body: formData });
        const data = await res.json();
        if (data.success) {
            showToast('Profile updated successfully!', 'success');
            setTimeout(() => window.location.reload(), 1200);
        } else {
            showToast(data.message || 'Update failed', 'error');
        }
    } catch (err) {
        showToast('Network error. Please try again.', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
    }
});

// ── Change Password ───────────────────────────────────────────────────────
document.getElementById('password-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const newPwd  = document.getElementById('new-password').value;
    const confPwd = document.getElementById('confirm-password').value;

    if (!newPwd) { showToast('Please enter a new password', 'warning'); return; }
    if (newPwd.length < 6) { showToast('Password must be at least 6 characters', 'warning'); return; }
    if (newPwd !== confPwd) { showToast('Passwords do not match', 'error'); return; }

    const btn = document.getElementById('save-pwd-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Updating…';

    try {
        const res  = await fetch('/api/users/profile', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: newPwd })
        });
        const data = await res.json();
        if (data.success) {
            showToast('Password changed successfully!', 'success');
            document.getElementById('new-password').value     = '';
            document.getElementById('confirm-password').value = '';
            document.getElementById('pwd-strength-wrap').classList.add('hidden');
        } else {
            showToast(data.message || 'Password update failed', 'error');
        }
    } catch (err) {
        showToast('Network error. Please try again.', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-key"></i> Update Password';
    }
});
</script>

<%- include('./partials/footer') %>
