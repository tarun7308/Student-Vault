<!-- Top Navbar -->
<header class="sv-navbar h-16 flex items-center justify-between px-5 sm:px-7 z-10 relative flex-shrink-0">
    
    <!-- Left: mobile toggle + search -->
    <div class="flex items-center gap-4 flex-1 min-w-0">
        <button onclick="toggleSidebar()" class="md:hidden w-9 h-9 rounded-lg flex items-center justify-center hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors" style="color: var(--text-muted);">
            <i class="fa-solid fa-bars"></i>
        </button>

        <!-- Breadcrumb / Search -->
        <div class="hidden sm:flex items-center rounded-xl px-4 py-2.5 gap-3 flex-1 max-w-sm" style="background: var(--bg-primary); border: 1.5px solid var(--border);">
            <i class="fa-solid fa-search text-sm" style="color: var(--text-muted);"></i>
            <input type="text" placeholder="Search books, students..." class="bg-transparent border-none outline-none text-sm flex-1" style="color: var(--text-primary); font-family: Outfit, sans-serif;" />
        </div>
    </div>

    <!-- Right: actions -->
    <div class="flex items-center gap-3 ml-4">
        
        <!-- Dark mode quick toggle (desktop) -->
        <button onclick="toggleDarkMode()" title="Toggle Dark Mode"
            class="hidden md:flex w-9 h-9 rounded-lg items-center justify-center transition-all hover:scale-110"
            style="background: var(--bg-primary); border: 1.5px solid var(--border); color: var(--text-muted);">
            <i id="navbar-dm-icon" class="fa-solid fa-moon text-sm"></i>
        </button>

        <!-- Notification Bell -->
        <div class="relative" id="notif-wrapper">
            <button id="notif-btn" onclick="toggleNotifPanel()"
                class="relative w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                style="background: var(--bg-primary); border: 1.5px solid var(--border); color: var(--text-muted);">
                <i class="fa-regular fa-bell text-sm"></i>
                <!-- Badge (hidden until count loaded) -->
                <span id="notif-badge"
                    class="absolute -top-1.5 -right-1.5 hidden min-w-[18px] h-[18px] px-1 rounded-full text-white text-[10px] font-bold flex items-center justify-center border-2"
                    style="background:#ef4444; border-color: var(--bg-card);">0</span>
            </button>

            <!-- Notification Panel -->
            <div id="notif-panel"
                class="hidden absolute right-0 mt-2 w-80 sm:w-96 rounded-2xl z-50 overflow-hidden animate-fade-in"
                style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: var(--shadow-lg);">

                <!-- Panel Header -->
                <div class="flex items-center justify-between px-4 py-3" style="border-bottom: 1px solid var(--border);">
                    <div class="flex items-center gap-2">
                        <i class="fa-regular fa-bell text-brand-500"></i>
                        <span class="font-bold text-sm" style="color: var(--text-primary);">Notifications</span>
                        <span id="notif-count-label" class="sv-badge sv-badge-blue text-xs hidden">0</span>
                    </div>
                    <button onclick="markAllRead()" class="text-xs font-semibold transition-colors hover:opacity-70" style="color: var(--accent);">
                        Mark all read
                    </button>
                </div>

                <!-- Notification List -->
                <div id="notif-list" class="overflow-y-auto" style="max-height: 380px;">
                    <!-- Loading state -->
                    <div id="notif-loading" class="flex flex-col items-center justify-center py-10 gap-3">
                        <i class="fa-solid fa-spinner fa-spin text-2xl" style="color: var(--text-muted);"></i>
                        <p class="text-sm" style="color: var(--text-muted);">Loading…</p>
                    </div>
                </div>

                <!-- Footer -->
                <div class="px-4 py-2.5 text-center" style="border-top: 1px solid var(--border);">
                    <p class="text-xs" style="color: var(--text-muted);">Notifications are generated from live data</p>
                </div>
            </div>
        </div>

        <!-- Divider -->
        <div class="h-7 w-px" style="background: var(--border);"></div>

        <!-- Profile Dropdown -->
        <div class="relative">
            <button onclick="document.getElementById('profile-dropdown').classList.toggle('hidden')"
                class="flex items-center gap-2.5 rounded-xl px-3 py-2 transition-all hover:scale-[1.02]"
                style="background: var(--bg-primary); border: 1.5px solid var(--border);">
                <img src="<%= user.profilePic ? user.profilePic : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=1485e0&color=fff&bold=true' %>"
                    alt="<%= user.name %>"
                    class="w-7 h-7 rounded-full object-cover ring-2 ring-brand-200">
                <div class="hidden sm:block text-left">
                    <p class="text-sm font-bold leading-none" style="color: var(--text-primary);"><%= user.name.split(' ')[0] %></p>
                    <p class="text-xs mt-0.5 capitalize" style="color: var(--text-muted);"><%= role %></p>
                </div>
                <i class="fa-solid fa-chevron-down text-xs hidden sm:block" style="color: var(--text-muted);"></i>
            </button>

            <!-- Dropdown -->
            <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-52 rounded-xl overflow-hidden z-50 animate-fade-in" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: var(--shadow-lg);">
                <div class="px-4 py-3" style="border-bottom: 1px solid var(--border);">
                    <p class="text-sm font-bold" style="color: var(--text-primary);"><%= user.name %></p>
                    <p class="text-xs mt-0.5" style="color: var(--text-muted);"><%= user.email %></p>
                </div>
                <% if (role === 'student') { %>
                <button onclick="openIdCard()" class="flex w-full items-center gap-3 px-4 py-2.5 text-sm hover:bg-brand-50 dark:hover:bg-slate-700 transition-colors" style="color: var(--text-secondary);">
                    <i class="fa-solid fa-id-card w-4" style="color: #1485e0;"></i> My ID Card
                </button>
                <% } %>
                <a href="/profile" class="flex items-center gap-3 px-4 py-2.5 text-sm transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.background='var(--bg-primary)'" onmouseout="this.style.background=''">
                    <i class="fa-regular fa-user w-4"></i> My Profile
                </a>
                <div style="height:1px; background: var(--border);"></div>
                <button onclick="handleLogout()" class="flex w-full items-center gap-3 px-4 py-2.5 text-sm text-red-500 transition-colors hover:bg-red-50 dark:hover:bg-red-950">
                    <i class="fa-solid fa-right-from-bracket w-4"></i> Sign Out
                </button>
            </div>
        </div>
    </div>
</header>

<!-- Student ID Card Modal -->
<% if (typeof user !== 'undefined' && role === 'student') { %>
<div id="idCardModal" class="sv-modal-overlay">
    <div class="animate-bounce-in">
        <div class="id-card" id="id-card-print">
            <div class="relative z-10">
                <div class="flex items-center gap-2 mb-5">
                    <i class="fa-solid fa-building-columns text-white opacity-90"></i>
                    <span class="font-bold text-white tracking-wider text-sm">StudentVault University Library</span>
                </div>
                <div class="flex items-center gap-4">
                    <img src="<%= user.profilePic ? user.profilePic : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=ffffff&color=0e3a5e&bold=true&size=80' %>"
                        class="w-16 h-16 rounded-xl object-cover border-2 border-white/30 shadow-lg">
                    <div>
                        <p class="font-bold text-xl text-white leading-tight"><%= user.name %></p>
                        <p class="text-blue-200 text-sm mt-0.5"><%= user.email %></p>
                        <span class="inline-block mt-2 px-3 py-0.5 rounded-full text-xs font-bold bg-white/20 text-white uppercase tracking-wider">Student</span>
                    </div>
                </div>
                <div class="mt-5 pt-4 flex items-center justify-between" style="border-top: 1px solid rgba(255,255,255,0.15);">
                    <div>
                        <p class="text-blue-300 text-xs">Library ID</p>
                        <p class="text-white font-bold text-sm font-mono tracking-widest">SV-<%= user._id ? user._id.toString().slice(-8).toUpperCase() : 'XXXXXXXX' %></p>
                    </div>
                    <div class="text-right">
                        <p class="text-blue-300 text-xs">Valid Till</p>
                        <p class="text-white font-bold text-sm"><%= new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toLocaleDateString('en-IN', {month:'short', year:'numeric'}) %></p>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex gap-3 mt-4 justify-center">
            <button onclick="window.print()" class="sv-btn sv-btn-primary">
                <i class="fa-solid fa-print"></i> Print Card
            </button>
            <button onclick="toggleModal('idCardModal')" class="sv-btn sv-btn-secondary">
                <i class="fa-solid fa-xmark"></i> Close
            </button>
        </div>
    </div>
</div>
<% } %>

<script>
function openIdCard() {
    document.getElementById('profile-dropdown').classList.add('hidden');
    toggleModal('idCardModal');
}

// ─── Dark Mode Icon Sync ───────────────────────────────────────────────────
(function() {
    function syncIcon() {
        const icon = document.getElementById('navbar-dm-icon');
        if (!icon) return;
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        icon.className = isDark ? 'fa-solid fa-sun text-sm text-amber-400' : 'fa-solid fa-moon text-sm';
    }
    syncIcon();
    const orig = window.toggleDarkMode;
    window.toggleDarkMode = function() {
        if (orig) orig();
        syncIcon();
        const dot  = document.getElementById('dark-toggle-dot');
        const pill = document.getElementById('dark-toggle-pill');
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (dot)  dot.style.transform  = isDark ? 'translateX(20px)' : 'translateX(0)';
        if (pill) pill.style.background = isDark ? '#1485e0' : 'rgba(255,255,255,0.15)';
    };
})();

// ─── Close dropdowns on outside click ─────────────────────────────────────
document.addEventListener('click', function(e) {
    // Profile dropdown
    const dd = document.getElementById('profile-dropdown');
    if (dd && !dd.classList.contains('hidden') &&
        !e.target.closest('[onclick*="profile-dropdown"]') && !dd.contains(e.target)) {
        dd.classList.add('hidden');
    }
    // Notification panel
    const np = document.getElementById('notif-panel');
    if (np && !np.classList.contains('hidden') &&
        !e.target.closest('#notif-wrapper')) {
        np.classList.add('hidden');
    }
});

// ─── Notification System ───────────────────────────────────────────────────
let _notifLoaded  = false;
let _notifData    = [];
let _readIds      = JSON.parse(localStorage.getItem('sv-read-notifs') || '[]');

// Colour / icon config per type
const _notifCfg = {
    success: { bg: '#d1fae5', color: '#065f46', dot: '#10b981' },
    error:   { bg: '#fee2e2', color: '#991b1b', dot: '#ef4444' },
    warning: { bg: '#fef3c7', color: '#92400e', dot: '#f59e0b' },
    info:    { bg: '#dbeafe', color: '#1e40af', dot: '#3b82f6'  },
};

function _timeAgo(dateStr) {
    const diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
    if (diff < 60)  return 'Just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
}

function _renderNotifications(data) {
    const list    = document.getElementById('notif-list');
    const badge   = document.getElementById('notif-badge');
    const counter = document.getElementById('notif-count-label');

    if (!data || data.length === 0) {
        list.innerHTML = `
            <div class="flex flex-col items-center justify-center py-12 gap-3">
                <div class="w-14 h-14 rounded-full flex items-center justify-center" style="background:var(--bg-primary);">
                    <i class="fa-regular fa-bell-slash text-2xl" style="color:var(--text-muted);"></i>
                </div>
                <p class="text-sm font-semibold" style="color:var(--text-primary);">All caught up!</p>
                <p class="text-xs" style="color:var(--text-muted);">No new notifications</p>
            </div>`;
        badge.classList.add('hidden');
        counter.classList.add('hidden');
        return;
    }

    // Count unread
    const unread = data.filter(n => !_readIds.includes(String(n.id))).length;

    // Badge
    if (unread > 0) {
        badge.textContent = unread > 9 ? '9+' : unread;
        badge.classList.remove('hidden');
        badge.style.display = 'flex';
        counter.textContent = unread + ' new';
        counter.classList.remove('hidden');
    } else {
        badge.classList.add('hidden');
        counter.classList.add('hidden');
    }

    // Build items
    let html = '';
    data.forEach(n => {
        const cfg    = _notifCfg[n.type] || _notifCfg.info;
        const isRead = _readIds.includes(String(n.id));
        html += `
        <a href="${n.link || '#'}"
            onclick="_markRead('${n.id}')"
            class="flex items-start gap-3 px-4 py-3 transition-all hover:opacity-90 cursor-pointer"
            style="background:${isRead ? 'transparent' : 'var(--bg-primary)'}; border-bottom:1px solid var(--border); text-decoration:none;">

            <!-- Icon Circle -->
            <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                style="background:${cfg.bg};">
                <i class="fa-solid ${n.icon} text-sm" style="color:${cfg.color};"></i>
            </div>

            <!-- Content -->
            <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                    <p class="text-xs font-bold" style="color:var(--text-primary);">${n.title}</p>
                    <span class="text-[10px] flex-shrink-0 mt-0.5" style="color:var(--text-muted);">${_timeAgo(n.time)}</span>
                </div>
                <p class="text-xs mt-0.5 leading-relaxed" style="color:var(--text-secondary);">${n.message}</p>
            </div>

            <!-- Unread Dot -->
            ${!isRead ? `<div class="w-2 h-2 rounded-full flex-shrink-0 mt-2" style="background:${cfg.dot};"></div>` : ''}
        </a>`;
    });

    list.innerHTML = html;
}

function _markRead(id) {
    if (!_readIds.includes(String(id))) {
        _readIds.push(String(id));
        localStorage.setItem('sv-read-notifs', JSON.stringify(_readIds));
    }
}

function markAllRead() {
    if (!_notifData.length) return;
    _notifData.forEach(n => _markRead(n.id));
    _renderNotifications(_notifData);
    showToast('All notifications marked as read', 'info', 2000);
}

async function _fetchNotifications() {
    if (_notifLoaded) { _renderNotifications(_notifData); return; }
    try {
        const res  = await fetch('/api/notifications', { credentials: 'same-origin' });
        const data = await res.json();
        if (data.success) {
            _notifData   = data.data || [];
            _notifLoaded = true;
            _renderNotifications(_notifData);
        } else {
            document.getElementById('notif-list').innerHTML =
                '<p class="text-center text-sm py-8" style="color:var(--text-muted);">Could not load notifications.</p>';
        }
    } catch (err) {
        document.getElementById('notif-list').innerHTML =
            '<p class="text-center text-sm py-8" style="color:var(--text-muted);">Network error.</p>';
    }
}

function toggleNotifPanel() {
    const panel = document.getElementById('notif-panel');
    const isHidden = panel.classList.contains('hidden');

    // Close profile dropdown if open
    document.getElementById('profile-dropdown')?.classList.add('hidden');

    if (isHidden) {
        panel.classList.remove('hidden');
        _fetchNotifications();
    } else {
        panel.classList.add('hidden');
    }
}

// Auto-load badge count on page load (silent, no panel open)
(async function initBadge() {
    try {
        const res  = await fetch('/api/notifications', { credentials: 'same-origin' });
        const data = await res.json();
        if (data.success && data.data) {
            _notifData   = data.data;
            _notifLoaded = true;
            const unread = data.data.filter(n => !_readIds.includes(String(n.id))).length;
            const badge  = document.getElementById('notif-badge');
            if (unread > 0 && badge) {
                badge.textContent  = unread > 9 ? '9+' : unread;
                badge.classList.remove('hidden');
                badge.style.display = 'flex';
            }
        }
    } catch (_) {}
})();
</script>
